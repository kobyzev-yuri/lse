# ============================================
# LSE Trading System configuration (template)
# ============================================
# Copy this file to config.env and tune parameters. API keys and DATABASE_URL may live here
# or in a separate config.secrets.env (see config.secrets.env.example): non-empty keys there override this file.
# Optional path: LSE_CONFIG_SECRETS=/path/to/secrets.env
# Process environment variables still win over both files (e.g. Docker compose `environment:`).

# ============================================
# GitHub (optional)
# ============================================
# Personal access token: scripts/API that read GITHUB_TOKEN from the environment.
# tradenews repo push: ./tradenews/scripts/push_github_from_config_env.sh (tradenews/config.env first, then this lse file).
# Optionally duplicate the token in tradenews/config.env — see tradenews/config.env.example.
# Otherwise use a git credential helper — see docs/DEPLOY.md.
# GITHUB_TOKEN=ghp_your_token_here

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/lse_trading

# ============================================
# OpenAI/ProxyAPI Configuration
# ============================================
# ProxyAPI key (or direct OpenAI). For direct OpenAI set OPENAI_GPT_KEY and OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_proxyapi_key_here
# Optional: key for direct OpenAI (gpt-4o). Check: python scripts/check_openai_gpt_key.py (local 403 by region is common; same key often works on server)
# OPENAI_GPT_KEY=sk-...
# Proxy: https://api.proxyapi.ru/openai/v1. Direct OpenAI: https://api.openai.com/v1 (in an allowed region on server)
# OpenRouter (via proxyapi): https://api.proxyapi.ru/openrouter/v1 — then OPENAI_MODEL = OpenRouter id (e.g. anthropic/claude-sonnet-4.6)
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT=60
# chat.completions: gpt-5.x / o1 / o3 / o4 — code uses max_completion_tokens instead of max_tokens (API requirement).
# Override: OPENAI_CHAT_USE_MAX_COMPLETION_TOKENS=1|0 if your proxy behaves differently.
# Trade analyzer /api/analyzer?use_llm=1: completion cap for large JSON (default 4096 / focus 6144).
# ANALYZER_LLM_MAX_COMPLETION_TOKENS=8192
# Compare several models: comma-separated "model" or "provider|model" (openai, anthropic, google)
# Example: gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# LLM_COMPARE_MODELS=gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# Model selection guide: docs/LLM_MODEL_SELECTION.md

# ============================================
# Embedding Configuration (vector KB — Vector KB)
# ============================================
# Local model (sentence-transformers / Hugging Face). Used when cloud embeddings are off.
# Examples: intfloat/multilingual-e5-base (multilingual, 768 dim), sentence-transformers/all-mpnet-base-v2
HF_MODEL_NAME=intfloat/multilingual-e5-base

# Cloud embeddings (if local model hits Bus error / core dumped):
# USE_OPENAI_EMBEDDINGS=true
# (same OPENAI_API_KEY and OPENAI_BASE_URL as for GPT; model text-embedding-3-small, 768 dim)
# Alternative — Gemini: USE_GEMINI_EMBEDDINGS=true, GEMINI_API_KEY=...

# ============================================
# Sentiment Analysis Configuration
# ============================================
# When ingesting news (CLI, CSV, web): compute sentiment via LLM immediately
SENTIMENT_AUTO_CALCULATE=true
# Who scores news sentiment: llm = paid LLM (OPENAI_MODEL, also yields insight); transformers = free local model (no insight).
# SENTIMENT_METHOD=transformers
SENTIMENT_METHOD=llm
# With SENTIMENT_METHOD=transformers — HuggingFace model (default FinBERT for finance text).
# SENTIMENT_MODEL=ProsusAI/finbert
# USE_LLM — global LLM use: false disables LLM; otherwise enabled.
# Drives: Telegram analyst (/signal, /recommend, /ask, /prompt_entry), trading_cycle_cron (ExecutionAgent),
# and the “with correlation (LLM)” block in game_5m reports (/pe_5m, /prompt_entry 5m, /recommend5m).
# Cron add_sentiment_to_news_cron (sentiment backfill on news). Later can live in DB (strategy_parameters GLOBAL).
# USE_LLM=false
USE_LLM=true

# ============================================
# Trading Configuration
# ============================================
# Initial capital and cash — local/risk_limits.json (risk_capacity.total_capital_usd).
# To raise cash: edit total_capital_usd and in DB: UPDATE portfolio_state SET quantity = <amount> WHERE ticker = 'CASH';
COMMISSION_RATE=0
# Portfolio stop-loss threshold: if price falls below this (log-return) the position closes. 0.95 ≈ −5%
STOP_LOSS_LEVEL=0.95
# Portfolio stop-loss: true = enforce STOP_LOSS_LEVEL; false = off (log warning; closes only on take-profit rules).
# Override in DB: strategy_parameters (GLOBAL) — PORTFOLIO_STOP_LOSS_ENABLED, STOP_LOSS_LEVEL.
PORTFOLIO_STOP_LOSS_ENABLED=true
# Portfolio exits take-profit only (true = ignore stop and other exits except take-profit).
PORTFOLIO_EXIT_ONLY_TAKE=false
# Sandbox: sell slippage (%). Fill price can be worse than last quote. 0 = off, 0.3 = conservative.
# SANDBOX_SLIPPAGE_SELL_PCT=0.3

# ============================================
# Games: fast (5m) and portfolio
# ============================================
# Focus: fast 5m game (daily on volatile names). Portfolio game is secondary — main effort on 5m.
# Correlation: “everything with everything” — traded 5m tickers + context (MSFT/META/AMZN, NVDA, SMH, QQQ, VIX, oil, forex).
# Cron: GAME 5m — send_sndk_signal_cron.py. Portfolio — trading_cycle_cron.py (optional).
# See docs/TICKER_GROUPS.md

# ---- Fast game (5m): pre-open forecasts first; trader acts manually; earlier info when possible ----
# Target names for daily (Alex: SNDK, NBIS — leaders; ASML, MU — AI; LITE, CIEN — volatile)
# Adding MSFT to FAST: pair correlation checks with Microsoft (find tickers stuck on NaN)
TICKERS_FAST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT
# Tickers the cron runs the 5m game for (entries/exits). Empty = all TICKERS_FAST.
GAME_5M_TICKERS=
# Correlation context (not traded in 5m): megacap + semis + VIX/oil/gold/forex + drivers (Chef/Alex 2026-04).
GAME_5M_CORRELATION_CONTEXT=MSFT,META,GOOGL,AMZN,NVDA,SMH,QQQ,TLT,^VIX,CL=F,GC=F,GBPUSD=X,ANET,INTC,DELL,ALAB,AVGO,ORCL,PLTR,AMD
# 5m correlation matrix (cron, LLM): default = 5m game + portfolio (/corr) + context above. Game+context only: GAME_5M_CORRELATION_EXCLUDE_PORTFOLIO=true
# GAME_5M_CORRELATION_EXCLUDE_PORTFOLIO=
# Cooldown between entry signal broadcasts per ticker (minutes)
GAME_5M_COOLDOWN_MINUTES=120
# send_sndk_signal_cron interval (minutes): must match crontab (see setup_cron.sh */N). 1 = more frequent entry/exit checks.
GAME_5M_SIGNAL_CRON_MINUTES=5
# Technical thresholds for get_decision_5m (RSI/momentum). Previously hardcoded — now here.
GAME_5M_RSI_STRONG_BUY_MAX=32
GAME_5M_MOMENTUM_STRONG_BUY_MIN=-0.3
GAME_5M_RSI_BUY_MAX=38
GAME_5M_PRICE_TO_LOW5D_MULT_MAX=1.005
GAME_5M_RSI_SELL_MIN=76
GAME_5M_RSI_HOLD_OVERBOUGHT_MIN=68
# Min RTH momentum (session / premarket 1m / cross-day) for momentum BUY; see recommend_5m.
GAME_5M_RTH_MOMENTUM_BUY_MIN=0.5
GAME_5M_RSI_FOR_MOMENTUM_BUY_MAX=62
GAME_5M_VOLATILITY_WARN_BUY_MIN=0.4
# Above — “wait” on entry (CAUTION / no BUY in noise). See docs/TRADE_EFFECTIVENESS_ANALYZER.md stage 1.
GAME_5M_VOLATILITY_WAIT_MIN=0.7
# VIX from DB quotes (^VIX): commentary in reasoning + optional relax of “very negative news → HOLD” when VIX < STRONG threshold (market pricing less fear).
GAME_5M_VIX_CONTEXT_ENABLED=true
GAME_5M_VIX_COMFORT_MAX=20
GAME_5M_VIX_STRONG_COMFORT_MAX=18
GAME_5M_VIX_RELAX_VERY_NEGATIVE_NEWS=true
# SELL confirmation: RSI on N prior 5m bars.
GAME_5M_SELL_CONFIRM_BARS=2
# 5m entry strategy: technical | llm. See docs/GAME_5M_BUY_DECISION_AND_LLM.md §0.
GAME_5M_ENTRY_STRATEGY=technical
# 5m strategy params (game5m_status, /game5m, API). Loss analysis: docs/GAME_5M_CLOSED_ANALYSIS.md
# 5m stop: false = take-profit / TIME_EXIT / SELL only (Alex: no loss stop)
GAME_5M_STOP_LOSS_ENABLED=false
# 5m exits take-profit only (true = disable STOP_LOSS/TIME_EXIT/SELL).
GAME_5M_EXIT_ONLY_TAKE=false
# External Platform POST /game (kerimsrv): after GAME_5m entry write — Telegram three lists (notOpened / opened / closed).
# Docs: kerimsrv/platform doc.md, image notes: kerimsrv/kdoc.md
# PLATFORM_GAME_API_ENABLED=false
# PLATFORM_GAME_API_URL=http://127.0.0.1:8080/game
# PLATFORM_GAME_API_TIMEOUT_SEC=15
GAME_5M_STOP_TO_TAKE_RATIO=0.5
GAME_5M_STOP_LOSS_PCT=1.5
GAME_5M_MAX_POSITION_DAYS=1
# Per ticker (if a run stretches 2–4 days): GAME_5M_MAX_POSITION_DAYS_NBIS=3. Tuning: scripts/suggest_max_position_days_5m.py
# GAME_5M_MAX_POSITION_DAYS_NBIS=3
# Daily rewrite into suggested_5m_params.json is no longer auto-merged into the game.
# 5m params come only from explicit GAME_5M_* in this file.
# (Key kept for compatibility; no effect on logic.)
USE_SUGGESTED_5M_PARAMS=false
GAME_5M_STOP_LOSS_MIN_PCT=0.5
# Take-profit cap (%). Momentum take: if 2h impulse >= GAME_5M_TAKE_PROFIT_MIN_PCT — take = min(impulse_2h × factor, cap); else take = cap. So 6% impulse triggers at 6%, not 7%.
GAME_5M_TAKE_PROFIT_PCT=7
# Ignore impulses below this % — take = cap (GAME_5M_TAKE_PROFIT_PCT). Otherwise take from 2h impulse (Alex: from 4%).
GAME_5M_TAKE_PROFIT_MIN_PCT=4.0
# ATR and volume thresholds (empty = disabled). Estimate: python scripts/estimate_5m_thresholds.py
GAME_5M_MIN_VOLUME_VS_AVG_PCT=
GAME_5M_MAX_ATR_5M_PCT=
# 2h impulse take factor: 1.0 = full impulse; <1 conservative; >1 aggressive (capped in code, max 2.0); still min(..., cap).
GAME_5M_TAKE_MOMENTUM_FACTOR=1.0
# Per-ticker take cap (optional): SNDK=8 → SNDK max 8%, others use GAME_5M_TAKE_PROFIT_PCT.
# GAME_5M_TAKE_PROFIT_PCT_SNDK=8
# GAME_5M_TAKE_PROFIT_PCT_MU=5
# Закрытие в кроне: VWAP по всем лотам GAME_5M (не только последний BUY). Отключить: GAME_5M_CLOSE_USE_GAME5M_VWAP=false
# Сужение тейка по результату scripts/backtest_game5m_param_hypotheses.py (JSON на сервере, например logs/hanger_tune_open.json):
# GAME_5M_HANGER_TUNE_JSON=/app/logs/hanger_tune_open.json
# GAME_5M_HANGER_TUNE_APPLY_TAKE=true
# Только для «висяков»: live-диагностика как в бэктесте; тогда срабатывающий тейк пишется как TAKE_PROFIT_SUSPEND.
# GAME_5M_HANGER_DUAL_MODE=true
# GAME_5M_HANGER_LIVE_CALENDAR_DAYS=6
# GAME_5M_HANGER_LIVE_SAG_EPSILON_LOG=0
# GAME_5M_HANGER_LIVE_SKIP_SAG=false
# Last N minutes of session (before 16:00 ET): plus PnL >= MIN_PROFIT_PCT → TIME_EXIT (except STRONG_BUY).
GAME_5M_SESSION_END_EXIT_MINUTES=30
GAME_5M_SESSION_END_MIN_PROFIT_PCT=0.3
# Entry quality guard (weak BUY/STRONG_BUY → HOLD on bad R:R/EV). Uncommented lines needed for web editor and analyzer auto_config_override.
GAME_5M_ENTRY_QUALITY_GUARD_ENABLED=false
GAME_5M_ENTRY_QUALITY_MIN_RR=1.2
GAME_5M_ENTRY_QUALITY_MIN_EV_PCT=0.0
# Finer hold limit (minutes). If set, overrides GAME_5M_MAX_POSITION_DAYS.
# GAME_5M_MAX_POSITION_MINUTES=
# GAME_5M_MAX_POSITION_MINUTES_SNDK=720
# GAME_5M_MAX_POSITION_MINUTES_CIEN=720
# Early de-risk exit from drawdown (TIME_EXIT_EARLY) when momentum/decision do not support holding.
# GAME_5M_EARLY_DERISK_ENABLED=false
# GAME_5M_EARLY_DERISK_MIN_AGE_MINUTES=180
# GAME_5M_EARLY_DERISK_MAX_LOSS_PCT=-2.0
# GAME_5M_EARLY_DERISK_MOMENTUM_BELOW=0.0
# LLM news block in 5m (docs/GAME_5M_NEWS.md); true only when news context is fresh.
GAME_5M_USE_LLM_NEWS=false
# CatBoost: extra signal in get_decision_5m (does not change entry rules). Deps: pip install -r requirements-catboost.txt
# Training plan: docs/ML_GAME5M_CATBOOST.md; script: python scripts/train_game5m_catboost.py
# GAME_5M_CATBOOST_ENABLED=false
# GAME_5M_CATBOOST_MODEL_PATH=local/models/game5m_entry_catboost.cbm
# Min closed trades with context_json for training (scripts/train_game5m_catboost.py)
# GAME_5M_CATBOOST_MIN_TRAIN_ROWS=60
# Append probability to reasoning: GAME_5M_CATBOOST_APPEND_REASONING=false
# Fuse CatBoost with technical entry and LLM (exits always technical_decision_core rules):
#   none — result = rules (default); hold_if_buy_below_p — BUY/STRONG_BUY→HOLD if P < threshold and CatBoost ok
# GAME_5M_CATBOOST_FUSION=none
# GAME_5M_CATBOOST_HOLD_BELOW_P=0.45

# Momentum BUY: min 5m bars in current RTH session (see recommend_5m). Else optional premarket 1m below.
# GAME_5M_MOMENTUM_MIN_SESSION_BARS=7
# Momentum BUY across “up to 2h” window through prior day: GAME_5M_MOMENTUM_ALLOW_CROSS_DAY_BUY=true
# Early RTH: if few 5m session bars — momentum from premarket 1m (first→last before 9:30 ET). Disable: false
# GAME_5M_EARLY_USE_PREMARKET_MOMENTUM=true
# Premarket momentum threshold for early BUY (%%). Below this premarket drift — no early momentum BUY:
# GAME_5M_PREMARKET_MOMENTUM_BLOCK_BELOW=-2.0
# GAME_5M_PREMARKET_MOMENTUM_BUY_MIN=0.5
# Cron scripts/send_sndk_signal_cron.py: second BUY in DB while position open = add-on. Default forbidden.
GAME_5M_ALLOW_PYRAMID_BUY=false
# First RTH hour (session_phase NEAR_OPEN): near daily high, PnL >= min % but below full take — close (fade protection after “chase”).
GAME_5M_SOFT_TAKE_NEAR_HIGH_ENABLED=true
# GAME_5M_SOFT_TAKE_NEAR_HIGH_MIN_PCT=2.0
# GAME_5M_SOFT_TAKE_MAX_PULLBACK_FROM_HIGH_PCT=0.35

# ---- Portfolio game (not in focus: Neutral, Mean Reversion, Momentum, etc.) ----
# Portfolio take-profit (%) when no explicit take at entry. 0 = do not close on take-profit rule alone.
PORTFOLIO_TAKE_PROFIT_PCT=0

# Premarket (scripts/premarket_cron.py): Telegram alert (gap, minutes to open).
PREMARKET_ALERT_TELEGRAM=false
# In premarket — add 5m forecast block for game tickers.
PREMARKET_ENTRY_PREVIEW_5M=true
# Stress tickers (forex, oil): gap below threshold → alert to close before open.
PREMARKET_STRESS_TICKERS=GBPUSD=X,EURUSD=X,CL=F
PREMARKET_STRESS_GAP_PCT=-1.5
PREMARKET_STRESS_ALERT_FRIDAY_ONLY=true
# Cron log errors → Telegram (scripts/cron_watchdog.py).
CRON_WATCHDOG_TELEGRAM=false

# ---- Portfolio game (daily strategies; not in focus — main effort on 5m) ----
# Pause portfolio trading: TRADING_CYCLE_ENABLED=false or unset — trading_cycle_cron and /api/execute skip trades. /portfolio, /recommend, /prompt_entry portfolio are read-only.
TRADING_CYCLE_ENABLED=false
# Tickers for KB and news ingest (Investing.com): FAST + MEDIUM + LONG.
# MEDIUM/LONG checked vs FAST correlation (scripts/check_medium_long_correlation_with_fast.py).
# Names without solid correlation to FAST are deferred — add here when quotes exist.
# Medium: semis / OEM / PLTR etc. for KB and analysis (not 5m game unless also in TICKERS_FAST). Chef list minus megacaps → LONG.
TICKERS_MEDIUM=ALAB,TER,AMD,ANET,INTC,DELL,AVGO,ORCL,PLTR
# Long: megacap tape (MSFT, META, GOOGL, AMZN, NVDA) + forex, commodities, VIX. Overlap with correlation list is OK for news ingest.
TICKERS_LONG=MSFT,META,GOOGL,AMZN,NVDA,ANET,INTC,DELL,ALAB,AVGO,ORCL,PLTR,AMD,SNDK,GBPUSD=X,GC=F,^VIX,CL=F,BZ=F
# OIL_TICKER=CL=F
# Explicit list for trading_cycle_cron (empty or unset = MEDIUM+LONG; cron when TRADING_CYCLE_ENABLED=true)
# TRADING_CYCLE_TICKERS=
# DASHBOARD_WATCHLIST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT,META,AMZN

# ============================================
# Web Interface Configuration
# ============================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
# /parameters: keys = uncommented lines in this file (except secrets in config_loader blocklist).
# Plus GAME_5M_TAKE_PROFIT_PCT_<T> / GAME_5M_MAX_POSITION_DAYS_<T> per TICKERS_FAST.
# Restart after web edits; empty — `docker compose restart lse` (docker must be in PATH; else exit 127).
# Example with full path: RESTART_CMD=/usr/bin/docker compose -f /path/to/lse/docker-compose.yml restart lse
RESTART_CMD=

# ============================================
# Analyzer autotune (evolutionary tuning)
# ============================================
# Idea: one change → wait window → compare → next.
# Default APPLY off: script only picks candidate and writes local/autotune_state.json.
# Run: python3 scripts/analyzer_autotune.py --days 5 --url http://127.0.0.1:8080/api/analyzer
ANALYZER_AUTOTUNE_APPLY=0
# New trades needed after apply before pending is marked ready_for_review.
ANALYZER_AUTOTUNE_MIN_TRADES=8
# Deny keys (comma-separated); by default do not touch cron keys.
ANALYZER_AUTOTUNE_DENY_KEYS=GAME_5M_SIGNAL_CRON_MINUTES
# Selection preference (comma-separated prefixes): per-ticker cap first, then factor.
ANALYZER_AUTOTUNE_PREFER_PREFIXES=GAME_5M_TAKE_PROFIT_PCT_,GAME_5M_TAKE_MOMENTUM_FACTOR
# State file path (if unset — local/autotune_state.json).
# ANALYZER_AUTOTUNE_STATE_PATH=/var/lib/lse/autotune_state.json

# ============================================
# News: sources, keys, tuning (knowledge_base)
# ============================================
# Map (names match NYSE where noted — one key can live in both config.env files):
#   Secrets:     NEWSAPI_KEY | ALPHAVANTAGE_KEY | MARKETAUX_API_KEY  (optional: NYSE_CONFIG_PATH → merge nyse/config.env)
#   Macro/aggregators: NewsAPI (+NEWSAPI_*), Alpha Vantage (+ALPHAVANTAGE_*, EARNINGS_*)
#   Ticker NYSE-style: Yahoo (no key) + Marketaux — TICKER_NEWS_* and MARKETAUX_API_KEY
#   Investing.com: INVESTING_NEWS_* (HTML feed); calendar — JSON API only (like nyse); INVESTING_CALENDAR_USE_HTML=true — legacy HTML
#   Central bank RSS: no keys (URLs in services/rss_news_fetcher.py)
# API limits: docs/NEWS_LIMITS.md. Ingest: scripts/fetch_news_cron.py (--mode all|core|core-fast|newsapi|investing|tickers).
#
# Knowledge base: save only TICKERS_* + MACRO (true) or all incoming from Alpha Vantage / LLM news (false — default).
# KB_INGEST_TRACKED_TICKERS_ONLY=false
#
# --- News volume for LLM / decisions (see docs/NEWS_LIMITS.md) ---
# Typical limits: NewsAPI developer ~100 HTTP requests/day — each PAGE = 1 request; macro + equity = 2+ requests per fetch_news_cron --mode newsapi run.
# Alpha Vantage free ~25 requests/day — do not enable extra economic/technical without need.
# Analyst/bot lookback (hours of KB news): default 336 h = 14 days.
# KB_NEWS_LOOKBACK_HOURS=336

# --- NewsAPI.org (key name matches NYSE: NEWSAPI_KEY) ---
# NewsAPI.org — news aggregator (free tier ~100 requests/day — each page = one request)
# NEWSAPI_KEY=your_newsapi_key_here
# Single combined macro query instead of five separate (default true). false — old mode (burns quota).
# NEWSAPI_MACRO_SINGLE_QUERY=true
# Custom query instead of built-in DEFAULT_MACRO_QUERY (long OR string); can add geopolitics: … OR (Ukraine OR Taiwan OR sanctions OR Gaza)
# NEWSAPI_MACRO_QUERY=
# Pages (~100 articles each) per macro run (1 = saves quota). Max 5. For more flow: 2–3.
# NEWSAPI_MAX_PAGES=2
# /everything "from" depth (days back). Code: up to 30. For two-week decisions: 14.
# NEWSAPI_DAYS_BACK=14
# Second query by portfolio tickers (OR symbols from EARNINGS_TRACK_TICKERS or TICKERS_FAST). +N pages see NEWSAPI_EQUITY_MAX_PAGES.
# NEWSAPI_FETCH_EQUITY=true
# NEWSAPI_EQUITY_MAX_PAGES=2
# Explicit ticker list for equity query (empty = EARNINGS_TRACK_TICKERS or TICKERS_FAST)
# NEWSAPI_EQUITY_TICKERS=SNDK,MU,MSFT,LITE,ALAB,TER
# After 429 pause NewsAPI N hours (cooldown file in logs). Reset: delete file.
# NEWSAPI_COOLDOWN_AFTER_429_HOURS=12
# After 426 Upgrade Required (plan/endpoint) — pause to avoid log spam every cron.
# NEWSAPI_COOLDOWN_AFTER_426_HOURS=24
# NEWSAPI_COOLDOWN_FILE=/app/logs/.newsapi_cooldown_until

# --- Alpha Vantage (key name matches NYSE: ALPHAVANTAGE_KEY; duplicate name: ALPHAVANTAGE_API_KEY) ---
# Alpha Vantage — Earnings Calendar and News Sentiment
# ALPHAVANTAGE_KEY=your_alphavantage_key_here
# Free plan: 25 requests/day. Economic and technical indicators burn quota — keep off unless needed:
# ALPHAVANTAGE_FETCH_ECONOMIC=false
# ALPHAVANTAGE_FETCH_TECHNICAL=false
# (defaults both false; then Earnings + News only.)
# Do not save Earnings Calendar to KB (“Earnings report for X” noise). Cleanup: scripts/cleanup_calendar_noise.py
# EARNINGS_CALENDAR_SAVE=false
# Tickers for Alpha Vantage Earnings (if EARNINGS_CALENDAR_SAVE=true): EARNINGS_TRACK_TICKERS=MSFT,SNDK,MU,LITE,ALAB,TER
# Timeouts/retries (optional): ALPHAVANTAGE_TIMEOUT=90 ALPHAVANTAGE_MAX_RETRIES=3 ALPHAVANTAGE_RETRY_DELAY=10 ALPHAVANTAGE_MIN_DELAY_SEC=1

# --- Marketaux (key name matches NYSE: MARKETAUX_API_KEY; supplements Yahoo, does not replace) ---
# Used in fetch_news_cron --mode tickers | core | all (TickerNews layer).
# MARKETAUX_API_KEY=your_marketaux_api_key_here
# Avoid duplicating key in two files: merge nyse/config.env (only fills empty LSE keys).
# NYSE_CONFIG_PATH=/home/you/projects/nyse/config.env

# --- Ticker news (NYSE-style): Yahoo (yfinance) + Marketaux merge ---
# Ticker list for ticker news. Empty = TICKERS_FAST.
# TICKER_NEWS_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT
# News window (hours), default 48.
# TICKER_NEWS_LOOKBACK_HOURS=48
# Yahoo: how many headlines per ticker, default 40.
# TICKER_NEWS_MAX_PER_TICKER=40
# knowledge_base exchange label (default NYSE).
# TICKER_NEWS_EXCHANGE=NYSE

# --------------------------------------------
# Investing.com News (stock-market-news feed)
# --------------------------------------------
# How many headlines to scan from feed per run (keyword filter; not all land in KB). 10–80.
# INVESTING_NEWS_MAX_ARTICLES=50
# Tickers — from TICKERS_FAST + MEDIUM + LONG (incl. ^VIX, commodities BZ=F, GC=F). Keywords are built-in
# (SNDK, AMD, CL=F, BZ=F, GC=F, ^VIX, etc.). Optional extra (adds to built-in, does not replace):
# Format: TICKER:word1,word2;OTHER:word3 (comma separates words; spaces in phrase allowed, e.g. "Brent Oil")
# INVESTING_NEWS_TICKER_KEYWORDS=SNDK:Citron,short;AMD:Advanced Micro Devices;BZ=F:Brent Oil;Brent;^VIX:VIX,volatility
# On 403 Forbidden set HTTP(S) proxy (browser or residential).
# Only http:// or https:// — socks5:// when loading config into env breaks model load (vector_kb).
# If no proxy — comment out or remove the line.
# INVESTING_NEWS_PROXY=http://user:pass@host:port
# HTML feed read timeout (sec), one retry on timeout. Default 55.
# INVESTING_NEWS_TIMEOUT=55
# true — drop article if headline matched a ticker not in KB list (legacy; many silent drops).
# false — save such rows as MACRO (default).
# INVESTING_NEWS_STRICT_TRACKED_ONLY=false

# --- KB /news: NYSE-style REG cluster (TF-IDF) for draft_impulse / gate (env names match nyse repo) ---
# NYSE_REGIME_CLUSTER=1
# NYSE_REGIME_CLUSTER_THRESHOLD=0.88
# NYSE_REGIME_CLUSTER_EMBED=tfidf
# (OpenAI embeddings not wired in LSE — if openai requested, code forces TF-IDF)

# --- Investing.com Economic Calendar (macro KB), like nyse — API only ---
# JSON API without key: services/investing_calendar_api.py. No auto-fallback to HTML.
# true — legacy HTML scrape by region only (do not enable unless API unavailable).
# INVESTING_CALENDAR_USE_HTML=false
# Use system proxy for calendar requests: INVESTING_CALENDAR_USE_SYSTEM_PROXY=true (PySocks for socks).

# Note: LLM news (USE_LLM_NEWS etc.) are not invoked from fetch_news_cron; cron uses RSS, NewsAPI, Alpha Vantage, TickerNews (Yahoo+Marketaux), Investing.

# ============================================
# Telegram Bot Configuration
# ============================================
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_SIGNAL_CHAT_ID=your_signal_chat_id
# TELEGRAM_ALLOWED_USERS=user_id1,user_id2
# TELEGRAM_WEBHOOK_URL=https://your-service.run.app/webhook
# Proxy for api.telegram.org if blocked: http://host:port or https://...
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# Signal broadcasts (send_sndk_signal_cron, premarket): comma-separated chats or single TELEGRAM_SIGNAL_CHAT_ID
# TELEGRAM_SIGNAL_CHAT_IDS=chat_id1,chat_id2
# TELEGRAM_SIGNAL_CHAT_ID=single_chat
# Mentions in messages (e.g. @username): TELEGRAM_SIGNAL_MENTIONS=@user1 @user2
# Dashboard chat (send_dashboard_cron): TELEGRAM_DASHBOARD_CHAT_ID=chat_id
# /closed and /closed_impulse report limits (HTML file to chat): default count and max N in command
# TELEGRAM_CLOSED_REPORT_DEFAULT=25
# TELEGRAM_CLOSED_REPORT_MAX=200
# Web /reports/closed and Excel: row cap (not below TELEGRAM_CLOSED_REPORT_MAX). Example: 500
# WEB_CLOSED_REPORT_MAX=500

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_DIR=logs

# Full option reference: docs/CONFIG_OPTIONS_ANALYSIS.md

