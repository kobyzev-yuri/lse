# ============================================
# LSE Trading System configuration (template)
# ============================================
# Copy this file to config.env and tune parameters. API keys and DATABASE_URL may live here
# or in a separate config.secrets.env (see config.secrets.env.example): non-empty keys there override this file.
# Optional path: LSE_CONFIG_SECRETS=/path/to/secrets.env
# Альтернативные имена путей (config_loader): см. docs/audit_code_to_example_2026-05-07.txt
# CONFIG_SECRETS_FILE=
# CONFIG_SECURITY_FILE=
# LSE_CONFIG_SECURITY=
# Process environment variables still win over both files (e.g. Docker compose `environment:`).

# ============================================
# GitHub (optional)
# ============================================
# Personal access token: scripts/API that read GITHUB_TOKEN from the environment.
# tradenews repo push: ./tradenews/scripts/push_github_from_config_env.sh (tradenews/config.env first, then this lse file).
# Optionally duplicate the token in tradenews/config.env — see tradenews/config.env.example.
# Otherwise use a git credential helper — see docs/DEPLOY.md.
# GITHUB_TOKEN=

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/lse_trading

# ============================================
# OpenAI/ProxyAPI Configuration
# ============================================
# ProxyAPI key (or direct OpenAI). For direct OpenAI set OPENAI_GPT_KEY and OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
# Optional: key for direct OpenAI (gpt-4o). Check: python scripts/check_openai_gpt_key.py (local 403 by region is common; same key often works on server)
# OPENAI_GPT_KEY=
# Proxy: https://api.proxyapi.ru/openai/v1. Direct OpenAI: https://api.openai.com/v1 (in an allowed region on server)
# OpenRouter (via proxyapi): https://api.proxyapi.ru/openrouter/v1 — then OPENAI_MODEL = OpenRouter id (e.g. mistralai/mistral-medium-3.1). GPT/Claude/Gemini у ProxyAPI — отдельные эндпоинты, не OpenRouter.
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT=60
# Дольше HTTP-таймаут для тяжёлых chat.completions: /prompt_entry game5m, LLM анализатора сделок (/api/analyzer use_llm=1). Пусто = как OPENAI_TIMEOUT.
OPENAI_TIMEOUT_PROMPT_ENTRY=300
#
# Anthropic (Claude) для основного чат-LLM — отдельные переменные; тот же ProxyAPI-ключ можно не дублировать (берётся OPENAI_API_KEY).
# См. https://proxyapi.ru/docs/openai-compatible-api и https://proxyapi.ru/docs/anthropic-models
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_BASE_URL=https://openai.api.proxyapi.ru/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_TIMEOUT=300
# Embeddings (vector_kb) по-прежнему используют OPENAI_BASE_URL / OPENAI_API_KEY, если включены.
# chat.completions: gpt-5.x / o1 / o3 / o4 — code uses max_completion_tokens instead of max_tokens (API requirement).
# Override: OPENAI_CHAT_USE_MAX_COMPLETION_TOKENS=1|0 if your proxy behaves differently.
# Trade analyzer /api/analyzer?use_llm=1: completion cap for large JSON (defaults 10240 / focus 8192; cap 16384).
# ANALYZER_LLM_MAX_COMPLETION_TOKENS=12288
# Температура для LLM блока анализатора (ниже OPENAI_TEMPERATURE по умолчанию); 0 = детерминированнее.
# ANALYZER_LLM_TEMPERATURE=0.05
# Compare several models: comma-separated "model" or "provider|model" (openai, anthropic, google)
# Example: gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# LLM_COMPARE_MODELS=gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# OpenRouter через ProxyAPI (полный base + id модели) — доп. запрос к той же задаче, что основной LLM:
# анализатор сделок (payload.llm.model_comparison) и входной анализ (llm_model_comparison в analyze_trading_situation).
# LLM_COMPARE_MODELS=https://api.proxyapi.ru/openrouter/v1|qwen/qwen3.6-27b
# Лимит completion для compare на входе (analyze_trading_situation); для Qwen thinking обычно нужно больше 2000.
# ENTRY_LLM_COMPARE_MAX_TOKENS=6144
# ENTRY_LLM_COMPARE_TEMPERATURE=0.2
# Model selection guide: docs/LLM_MODEL_SELECTION.md

# ============================================
# Embedding Configuration (vector KB — Vector KB)
# ============================================
# Local model (sentence-transformers / Hugging Face). Used when cloud embeddings are off.
# Examples: intfloat/multilingual-e5-base (multilingual, 768 dim), sentence-transformers/all-mpnet-base-v2
HF_MODEL_NAME=intfloat/multilingual-e5-base

# Cloud embeddings (if local model hits Bus error / core dumped):
# USE_OPENAI_EMBEDDINGS=true
# (same OPENAI_API_KEY and OPENAI_BASE_URL as for GPT; model text-embedding-3-small, 768 dim)
# Alternative — Gemini: USE_GEMINI_EMBEDDINGS=true, GEMINI_API_KEY=

# ============================================
# Sentiment Analysis Configuration
# ============================================
# When ingesting news (CLI, CSV, web): compute sentiment via LLM immediately
SENTIMENT_AUTO_CALCULATE=true
# Who scores news sentiment: llm = paid LLM (OPENAI_MODEL, also yields insight); transformers = free local model (no insight).
# SENTIMENT_METHOD=transformers
SENTIMENT_METHOD=llm
# With SENTIMENT_METHOD=transformers — HuggingFace model (default FinBERT for finance text).
# SENTIMENT_MODEL=ProsusAI/finbert
# USE_LLM — global LLM use: false disables LLM; otherwise enabled.
# Drives: Telegram analyst (/signal, /recommend, /ask, /prompt_entry), trading_cycle_cron (ExecutionAgent),
# and the “with correlation (LLM)” block in game_5m reports (/pe_5m, /prompt_entry 5m, /recommend5m).
# Cron add_sentiment_to_news_cron (sentiment backfill on news). Later can live in DB (strategy_parameters GLOBAL).
# USE_LLM=false
USE_LLM=true

# ============================================
# Trading Configuration
# ============================================
# Initial capital and cash — local/risk_limits.json (risk_capacity.total_capital_usd).
# To raise cash: edit total_capital_usd and in DB: UPDATE portfolio_state SET quantity = <amount> WHERE ticker = 'CASH';
# Paper / dev without local/risk_limits.json: wide portfolio limits from config/risk_limits.sandbox.json
# RISK_LIMITS_PROFILE=sandbox
# LSE_SANDBOX=1
COMMISSION_RATE=0
# Portfolio stop-loss threshold: if price falls below this (log-return) the position closes. 0.95 ≈ −5%
STOP_LOSS_LEVEL=0.95
# Portfolio stop-loss: true = enforce STOP_LOSS_LEVEL; false = off (current policy: take-profit / explicit exits only).
# Override in DB: strategy_parameters (GLOBAL) — PORTFOLIO_STOP_LOSS_ENABLED, STOP_LOSS_LEVEL.
PORTFOLIO_STOP_LOSS_ENABLED=false
# Portfolio exits take-profit only (true = ignore stop and other exits except take-profit).
PORTFOLIO_EXIT_ONLY_TAKE=false
# Sandbox: sell slippage (%). Fill price can be worse than last quote. 0 = off, 0.3 = conservative.
# SANDBOX_SLIPPAGE_SELL_PCT=0.3

# ============================================
# Games: fast (5m) and portfolio
# ============================================
# Focus: fast 5m game (daily on volatile names). Portfolio game is secondary — main effort on 5m.
# Correlation: “everything with everything” — traded 5m tickers + context (MSFT/META/AMZN, NVDA, SMH, QQQ, VIX, oil, forex).
# Cron: GAME 5m — send_sndk_signal_cron.py. Portfolio — trading_cycle_cron.py (optional).
# See docs/TICKER_GROUPS.md

# ---- Fast game (5m): pre-open forecasts first; trader acts manually; earlier info when possible ----
# Target names for daily (Alex: SNDK, NBIS — leaders; ASML, MU — AI; LITE, CIEN — volatile)
# Adding MSFT to FAST: pair correlation checks with Microsoft (find tickers stuck on NaN)
TICKERS_FAST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT
# Только индикаторы/без торгового контура (services/ticker_groups): через запятую или пусто.
# TICKERS_INDICATOR_ONLY=
# Tickers the cron runs the 5m game for (entries/exits). Empty = all TICKERS_FAST.
GAME_5M_TICKERS=
# Correlation context (not traded in 5m): megacap + semis + ^NDX/QQQ + VIX/oil/gold/forex + drivers (Chef/Alex 2026-04).
GAME_5M_CORRELATION_CONTEXT=MSFT,META,GOOGL,AMZN,NVDA,SMH,^NDX,QQQ,TLT,^VIX,CL=F,GC=F,GBPUSD=X,ANET,INTC,DELL,ALAB,AVGO,ORCL,PLTR,AMD
# Daily index quotes for market_regime_daily (cron 23:32) and ML event features.
# ^NDX = Nasdaq-100 (индекс); ndx_gap_pct в technical params recommend_5m. См. docs/ML_GLOSSARY_RU.md §6
MARKET_INDEX_TICKERS=SPY,^NDX,DIA,^VIX
MARKET_REGIME_NDX_TICKER=^NDX
MARKET_REGIME_NDX_FALLBACK_TICKER=QQQ
# 5m correlation matrix (cron, LLM): default = 5m game + portfolio (/corr) + context above. Game+context only: GAME_5M_CORRELATION_EXCLUDE_PORTFOLIO=true
# GAME_5M_CORRELATION_EXCLUDE_PORTFOLIO=
# Cooldown between entry signal broadcasts per ticker (minutes)
GAME_5M_COOLDOWN_MINUTES=120
# send_sndk_signal_cron interval (minutes): must match crontab (see setup_cron.sh */N). 1 = more frequent entry/exit checks.
GAME_5M_SIGNAL_CRON_MINUTES=5
# Technical thresholds for get_decision_5m (RSI/momentum). Previously hardcoded — now here.
GAME_5M_RSI_STRONG_BUY_MAX=32
GAME_5M_MOMENTUM_STRONG_BUY_MIN=-0.3
GAME_5M_RSI_BUY_MAX=38
GAME_5M_PRICE_TO_LOW5D_MULT_MAX=1.005
GAME_5M_RSI_SELL_MIN=76
GAME_5M_RSI_HOLD_OVERBOUGHT_MIN=68
# Min RTH momentum (session / premarket 1m / cross-day) for momentum BUY; see recommend_5m.
GAME_5M_RTH_MOMENTUM_BUY_MIN=0.5
GAME_5M_RSI_FOR_MOMENTUM_BUY_MAX=62
GAME_5M_VOLATILITY_WARN_BUY_MIN=0.4
# Above — “wait” on entry (CAUTION / no BUY in noise). See docs/TRADE_EFFECTIVENESS_ANALYZER.md stage 1.
GAME_5M_VOLATILITY_WAIT_MIN=0.7
# Decision stack: единый decision_snapshot в context_json (docs/DECISION_STACK_ROLLOUT_PLAN.md).
# DECISION_STACK_ENABLED=true
# DECISION_STACK_RESOLVE_ENABLED=false
# false (default): legacy исполняет; stack пишет snapshot + projected_effective_if_resolve.
# true: stack становится исполнителем (veto session NEAR_OPEN/CLOSE и др.). Включать вручную, если mirror-статистика ухудшится — см. docs/ML_CONSOLIDATION_ROLLOUT_PLAN.md §3.0 policy.
# DECISION_STACK_OWN_FINALIZE=true
# true (default): CatBoost+multiday в apply_game5m_policy_gates → technical_decision_effective (legacy hot path).
# Promotion на legacy — через *_ENABLED / *_GATE_MODE каждого контура, не через RESOLVE. См. docs/ML_STATUS_REPORT.md.
# Фаза 2 — гейты контуров (none|log_only|apply); при RESOLVE=false в snapshot виден projected_effective_if_resolve.
# DECISION_STACK_ENTRY_ADVICE_GATE_MODE=log_only
# DECISION_STACK_MACRO_GATE_MODE=log_only
# DECISION_STACK_NEWS_FUSION_GATE_MODE=log_only
# DECISION_STACK_NEWS_FUSION_VETO_BELOW=-0.35
# DECISION_STACK_FORECAST_GATE_MODE=log_only
# DECISION_STACK_FORECAST_CHASE_GAP_MIN_PCT=1.0
# DECISION_STACK_FORECAST_BEARISH_MULTIDAY_PCT=0.15
# DECISION_STACK_CATBOOST_GATE_MODE=apply
# DECISION_STACK_MULTIDAY_GATE_MODE=apply
# Portfolio stack: resolve applies only when model/readiness gates are production-ready.
# DECISION_STACK_PORTFOLIO_RESOLVE_ENABLED=false
# DECISION_STACK_PORTFOLIO_CATBOOST_GATE_MODE=log_only
# DECISION_STACK_EVENT_REACTION_GATE_MODE=log_only
# Emergency/manual readiness override when nightly ml_train_readiness.jsonl is absent or stale
# (allowed values: telemetry|caution|production).
# DECISION_STACK_READINESS_CATBOOST_ENTRY_5M=
# DECISION_STACK_READINESS_PORTFOLIO_CATBOOST=
# DECISION_STACK_READINESS_EVENT_REACTION=
# DECISION_STACK_READINESS_RECOVERY_ML=
# Naive multiday log-return ridge: daily closes + optional 5m vol/mom tail + optional DB premarket. Docs: docs/GAME_5M_MULTIDAY_LR_RIDGE.md, calibration phases: docs/ML_CALIBRATION_PHASES.md (no entry/exit override by default).
# GAME_5M_MULTIDAY_LR_REG_ENABLED=false
# GAME_5M_MULTIDAY_LR_REG_APPEND_REASONING=false
# GAME_5M_MULTIDAY_LR_REG_PERIOD_DAYS=400
# GAME_5M_MULTIDAY_LR_REG_RIDGE_LAMBDA=1.0
# GAME_5M_MULTIDAY_LR_REG_MIN_SAMPLES=80
# GAME_5M_MULTIDAY_LR_REG_USE_5M_TAIL=true
# Премаркет из БД (premarket_daily_features) в ridge-строке обучения/онлайн-прогноза:
# GAME_5M_MULTIDAY_LR_USE_PREMARKET_DB=true
# Enrichment v3 (default off until ingest + walk-forward): news / macro calendar / symbol earnings daily features.
# GAME_5M_MULTIDAY_LR_USE_NEWS_DB=false
# GAME_5M_MULTIDAY_LR_USE_MACRO_CALENDAR_DB=false
# GAME_5M_MULTIDAY_LR_USE_SYMBOL_CALENDAR_DB=false
# Анализатор: walk-forward v2 vs v3n/v3mac/v3sym/v3 и рекомендации по флагам выше (дольше ~5× walk-forward).
# GAME_5M_MULTIDAY_LR_ANALYZER_COMPARE_FEATURE_SETS=true
# Дневные close для онлайн-ridge: auto = сначала public.quotes (если ≥40 дней), при нехватке строк обучения — Yahoo; quotes | yahoo — принудительно.
# GAME_5M_MULTIDAY_LR_DAILY_CLOSE_SOURCE=auto
# Multiday ridge gates (фаза D): none | log_only | apply. Шаг 1 — log_only (телеметрия в context_json / логах).
# GAME_5M_MULTIDAY_ENTRY_GATE_MODE=log_only
# GAME_5M_MULTIDAY_HOLD_GATE_MODE=log_only
# GAME_5M_MULTIDAY_ENTRY_TAU_1D_PCT=0.25
# GAME_5M_MULTIDAY_ENTRY_TAU_PCT=0.15
# GAME_5M_MULTIDAY_ENTRY_NEGATIVE_HORIZONS_MIN=2
# GAME_5M_MULTIDAY_HOLD_TAU_PCT=0.20
# GAME_5M_MULTIDAY_HOLD_POSITIVE_HORIZONS_MIN=2
# GAME_5M_MULTIDAY_HOLD_MAX_LOSS_PCT=-4.0
# GAME_5M_MULTIDAY_HOLD_EXIT_DETAILS=early_derisk,stale_reversal
# Overnight risk (не уносить лонг через close при медвежьем 1–3d ridge / плохом премаркет-гэпе):
# GAME_5M_EOD_FLATTEN_ENABLED=true
# GAME_5M_EOD_FLATTEN_MINUTES_BEFORE_CLOSE=20
# GAME_5M_EOD_FLATTEN_ALWAYS=true
GAME_5M_BLOCK_NEW_BUY_NEAR_CLOSE_ENABLED=true
GAME_5M_BLOCK_NEW_BUY_MINUTES_BEFORE_CLOSE=90
GAME_5M_BLOCK_NEW_BUY_ON_BEARISH_MULTIDAY=true
GAME_5M_MULTIDAY_OVERNIGHT_GATE_MODE=apply
# GAME_5M_PREMARKET_AUTO_FLAT_ENABLED=true
# GAME_5M_PREMARKET_GAP_FLAT_PCT=-2.0
# GAME_5M_PREMARKET_AUTO_FLAT_USE_GAP=true
# GAME_5M_PREMARKET_AUTO_FLAT_USE_MULTIDAY=true
# VIX from DB quotes (^VIX): commentary in reasoning + optional relax of “very negative news → HOLD” when VIX < STRONG threshold (market pricing less fear).
GAME_5M_VIX_CONTEXT_ENABLED=true
GAME_5M_VIX_COMFORT_MAX=20
GAME_5M_VIX_STRONG_COMFORT_MAX=18
GAME_5M_VIX_RELAX_VERY_NEGATIVE_NEWS=true
# SELL confirmation: RSI on N prior 5m bars.
GAME_5M_SELL_CONFIRM_BARS=2
# 5m entry strategy: technical | llm. See docs/GAME_5M_BUY_DECISION_AND_LLM.md §0.
GAME_5M_ENTRY_STRATEGY=technical
# 5m strategy params (game5m_status, /game5m, API). Algorithm/reporting: docs/GAME_5M_CALCULATIONS_AND_REPORTING.md; analyzer: docs/TRADE_EFFECTIVENESS_ANALYZER.md
# 5m stop: false = take-profit / TIME_EXIT / SELL only (Alex: no loss stop)
GAME_5M_STOP_LOSS_ENABLED=false
# 5m exits take-profit only (true = disable STOP_LOSS/TIME_EXIT/SELL except stale/derisk on loss close).
GAME_5M_EXIT_ONLY_TAKE=true
# External Platform POST /game (kerimsrv): after GAME_5m entry write — Telegram three lists (notOpened / opened / closed).
# Docs: kerimsrv/platform doc.md, image notes: kerimsrv/kdoc.md
# PLATFORM_GAME_API_ENABLED=false
# PLATFORM_GAME_API_URL=http://127.0.0.1:8080/game
# PLATFORM_GAME_API_TIMEOUT_SEC=15
GAME_5M_STOP_TO_TAKE_RATIO=0.5
GAME_5M_STOP_LOSS_PCT=1.5
GAME_5M_MAX_POSITION_DAYS=1
# Per ticker (if a run stretches 2–4 days): GAME_5M_MAX_POSITION_DAYS_NBIS=3. Tuning: scripts/suggest_max_position_days_5m.py
# GAME_5M_MAX_POSITION_DAYS_NBIS=3
# Daily rewrite into suggested_5m_params.json is no longer auto-merged into the game.
# 5m params come only from explicit GAME_5M_* in this file.
# (Key kept for compatibility; no effect on logic.)
USE_SUGGESTED_5M_PARAMS=false
GAME_5M_STOP_LOSS_MIN_PCT=0.5
# Take-profit cap (%). Momentum take: if 2h impulse >= GAME_5M_TAKE_PROFIT_MIN_PCT — take = min(impulse_2h × factor, cap); else take = cap. So 6% impulse triggers at 6%, not 7%.
GAME_5M_TAKE_PROFIT_PCT=7.5
# Ignore impulses below this % — take = cap (GAME_5M_TAKE_PROFIT_PCT). Otherwise take from 2h impulse (Alex: from 4%).
GAME_5M_TAKE_PROFIT_MIN_PCT=4.0
# ATR and volume thresholds (empty = disabled). Estimate: python scripts/estimate_5m_thresholds.py
GAME_5M_MIN_VOLUME_VS_AVG_PCT=
GAME_5M_MAX_ATR_5M_PCT=0.8
# 2h impulse take factor: 1.0 = full impulse; <1 conservative; >1 aggressive (capped in code, max 2.0); still min(..., cap).
GAME_5M_TAKE_MOMENTUM_FACTOR=1.55
# Hanger tune JSON (offline bundle / open / json). Empty = off. Uncommented so /parameters and analyzer auto_config_override can touch keys.
GAME_5M_HANGER_TUNE_JSON=
# If true and JSON set: min(remediation_take_cap, take cap) for diagnosed hangers; live may record TAKE_PROFIT_SUSPEND.
GAME_5M_HANGER_TUNE_APPLY_TAKE=false
# Do not let stale hanger caps force a take when live PnL is already far above the hanger cap.
GAME_5M_HANGER_CAP_OVERRIDE_MARGIN_PCT=2.0
# Per-ticker take cap (optional): SNDK=8 → SNDK max 8%, others use GAME_5M_TAKE_PROFIT_PCT.
# GAME_5M_TAKE_PROFIT_PCT_SNDK=8
# GAME_5M_TAKE_PROFIT_PCT_MU=5
# Закрытие в кроне: VWAP по всем лотам GAME_5M (не только последний BUY).
# GAME_5M_CLOSE_USE_GAME5M_VWAP=true
# Пример пути на сервере: GAME_5M_HANGER_TUNE_JSON=/app/logs/hanger_tune_open.json
# Только для «висяков»: live-диагностика как в бэктесте; тогда срабатывающий тейк пишется как TAKE_PROFIT_SUSPEND.
# GAME_5M_HANGER_DUAL_MODE=true
# GAME_5M_HANGER_LIVE_CALENDAR_DAYS=6
# GAME_5M_HANGER_LIVE_SAG_EPSILON_LOG=0
# GAME_5M_HANGER_LIVE_SKIP_SAG=false
# Last N minutes of session (before 16:00 ET): plus PnL >= MIN_PROFIT_PCT → TIME_EXIT (except STRONG_BUY).
GAME_5M_SESSION_END_EXIT_MINUTES=30
GAME_5M_SESSION_END_MIN_PROFIT_PCT=0.3
# Entry quality guard (weak BUY/STRONG_BUY → HOLD on bad R:R/EV). Uncommented lines needed for web editor and analyzer auto_config_override.
GAME_5M_ENTRY_QUALITY_GUARD_ENABLED=false
GAME_5M_ENTRY_QUALITY_MIN_RR=1.2
GAME_5M_ENTRY_QUALITY_MIN_EV_PCT=0.0
# Finer hold limit (minutes). If set, overrides GAME_5M_MAX_POSITION_DAYS.
# GAME_5M_MAX_POSITION_MINUTES=
# GAME_5M_MAX_POSITION_MINUTES_SNDK=720
# GAME_5M_MAX_POSITION_MINUTES_CIEN=720
# Early de-risk exit from drawdown (TIME_EXIT_EARLY) when momentum/decision do not support holding.
# With GAME_5M_EXIT_ONLY_TAKE=true, early_derisk still runs when close PnL < 0 (before take-by-high).
# Prod bundle: config/game_5m_exit_recommended.env + scripts/apply_game_5m_exit_config.sh
GAME_5M_EARLY_DERISK_ENABLED=true
GAME_5M_EARLY_DERISK_MIN_AGE_MINUTES=240
GAME_5M_EARLY_DERISK_MAX_LOSS_PCT=-2.2
GAME_5M_EARLY_DERISK_MOMENTUM_BELOW=-0.2
# Stale/reversal exit: closes old GAME_5M longs whose setup degraded (HOLD/SELL + weak momentum + negative PnL).
# Checked before GAME_5M_EXIT_ONLY_TAKE; with close < 0 also before TAKE_PROFIT (no wick-take in loss).
GAME_5M_STALE_REVERSAL_EXIT_ENABLED=true
GAME_5M_STALE_REVERSAL_MIN_AGE_MINUTES=570
# GAME_5M_STALE_REVERSAL_MIN_AGE_MINUTES_NBIS=960
GAME_5M_STALE_REVERSAL_MAX_PNL_PCT=-2.5
# GAME_5M_STALE_REVERSAL_MAX_PNL_PCT_NBIS=-3.0
GAME_5M_STALE_REVERSAL_MOMENTUM_BELOW=-0.3
# Guard against ambiguous 09:25–09:30 bucket right after open (see incident writeups in docs/archive).
GAME_5M_EXIT_GUARD_FIRST_MINUTES=5
# Hanger Definition v2 diagnostics (logged to SELL context_json; rule-based baseline for future ML).
# GAME_5M_HANGER_V2_ENABLED=false
# GAME_5M_HANGER_V2_RECOVERABLE_MIN_AGE_MINUTES=390
# GAME_5M_HANGER_V2_RECOVERABLE_MIN_PNL_PCT=-1.0
# GAME_5M_HANGER_V2_RECOVERABLE_MAX_PNL_PCT=1.0
# GAME_5M_HANGER_V2_WEAK_MOMENTUM_BELOW=0.5
# GAME_5M_HANGER_V2_STALE_MAX_PNL_PCT=-1.5
# GAME_5M_HANGER_V2_STALE_MOMENTUM_BELOW=0.0
# Continuation / underprofit gate diagnostics (log-only by default; does not change exits yet).
# GAME_5M_CONTINUATION_GATE_ENABLED=false
# GAME_5M_CONTINUATION_GATE_LOG_ONLY=true
# GAME_5M_CONTINUATION_MIN_PNL_PCT=2.0
# GAME_5M_CONTINUATION_MIN_MOMENTUM_2H_PCT=1.0
# GAME_5M_CONTINUATION_MAX_RSI_5M=72
# GAME_5M_CONTINUATION_MIN_VOLUME_VS_AVG_PCT=0
# GAME_5M_CONTINUATION_EXTEND_TAKE_ADD_PCT=1.0
# GAME_5M_CONTINUATION_MAX_EXTRA_MINUTES=120
# GAME_5M_CONTINUATION_TRAIL_PULLBACK_PCT=0.7
# For strong 2h momentum, allow a wider continuation trailing pullback before closing.
# GAME_5M_CONTINUATION_TRAIL_MOMENTUM_SCALE_ABOVE_PCT=3.0
# GAME_5M_CONTINUATION_TRAIL_MOMENTUM_SCALE=1.5
# LLM news block in 5m (docs/GAME_5M_NEWS.md); true only when news context is fresh.
GAME_5M_USE_LLM_NEWS=false
# CatBoost: extra signal in get_decision_5m (does not change entry rules). Deps: pip install -r requirements-catboost.txt
# Training plan: docs/ML_GAME5M_CATBOOST.md; script: python scripts/train_game5m_catboost.py
# GAME_5M_CATBOOST_ENABLED=false
# CatBoost model artifacts should be written into /app/logs (bind-mounted on VM), not /app/local.
GAME_5M_CATBOOST_MODEL_PATH=/app/logs/ml/models/game5m_entry_catboost.cbm
# Min closed trades with context_json for training (scripts/train_game5m_catboost.py)
# GAME_5M_CATBOOST_MIN_TRAIN_ROWS=60
# Append probability to reasoning:
# GAME_5M_CATBOOST_APPEND_REASONING=false
# Fuse CatBoost with technical entry and LLM (exits always technical_decision_core rules):
#   none — result = rules (default); hold_if_buy_below_p — BUY/STRONG_BUY→HOLD if P < threshold and CatBoost ok
# GAME_5M_CATBOOST_FUSION=none
# GAME_5M_CATBOOST_HOLD_BELOW_P=0.45
# Multiday ridge: JSON артефакты по тикеру (TICKER.json), тот же bind-mount что CatBoost — см. docs/GAME_5M_MULTIDAY_LR_RIDGE.md
# GAME_5M_MULTIDAY_LR_MODEL_DIR=/app/logs/ml/models/multiday_lr

# Recovery ML dataset (analyzer only; docs/GAME_5M_TIME_EXIT_RECOVERY_PLAN.md phase C). Not used in live game_5m exits.
# GAME_5M_RECOVERY_ML_HORIZONS_MINUTES=120,390
# GAME_5M_RECOVERY_ML_EPS_UP_PCT=0.5
# GAME_5M_RECOVERY_ML_MAX_ADVERSE_PCT=-3.0
# Optional: only bars with pnl_pct <= this %% (e.g. -0.5) — “near early exit” proxy
# GAME_5M_RECOVERY_DATASET_NEAR_EARLY_PCT=
# GAME_5M_RECOVERY_ML_MAX_ROWS_PER_TRADE=48
# GAME_5M_RECOVERY_ML_ROW_STRIDE=1
# GAME_5M_RECOVERY_ML_MAX_TOTAL_ROWS=80000
# Fixed path for JSONL when export_recovery_ml=1 (else LOG_DIR + timestamp)
# ANALYZER_RECOVERY_ML_EXPORT_PATH=
# Training input for scripts/train_game5m_recovery_catboost.py (optional; can pass --jsonl)
# GAME_5M_RECOVERY_TRAIN_JSONL=
# GAME_5M_RECOVERY_CATBOOST_MODEL_PATH=/app/logs/ml/models/game5m_recovery_catboost.cbm
# GAME_5M_RECOVERY_ML_MIN_TRAIN_ROWS=400
# Analyzer scenario backtest (D3): delay exit if recovery P < tau
# GAME_5M_RECOVERY_SCENARIO_TAU=0.45
# GAME_5M_RECOVERY_SCENARIO_DELAY_BARS=6
# Live game_5m hook (D4): off until reviewed
# GAME_5M_RECOVERY_ML_ENABLED=false
# D4a: log-only telemetry in SELL context_json for TIME_EXIT_EARLY (no behavior change).
# When enabled, the cron will compute recovery_proba and whether we *would* defer exit.
# Apply mode is for D4b after review: GAME_5M_RECOVERY_ML_LOG_ONLY=false.
# GAME_5M_RECOVERY_ML_LOG_ONLY=true
# Gate: hold if P(recovery) >= tau (subject to guards below).
# GAME_5M_RECOVERY_LIVE_TAU_HOLD=0.65
# How many 5m bars to defer TIME_EXIT_EARLY (D4b apply only).
# GAME_5M_RECOVERY_LIVE_DEFER_BARS=6
# Restrict gating to one exit_detail (empty = all). Recommended for first rollout: stale_reversal only.
# GAME_5M_RECOVERY_ONLY_EXIT_DETAIL=stale_reversal
# Hard guards: never defer if PnL too deep or momentum collapsed.
# GAME_5M_RECOVERY_HARD_STOP_LOSS_PCT=-3.0
# GAME_5M_RECOVERY_HARD_STOP_MOMENTUM_2H_PCT=-2.0
# Never defer if position is too old (minutes since entry), or too close to session end.
# GAME_5M_RECOVERY_DEFER_MAX_AGE_MINUTES=780
# GAME_5M_RECOVERY_DEFER_NEAR_CLOSE_MINUTES=45
# D4a накопление τ×K: ежедневный rollup в JSONL (scripts/run_recovery_d4a_stats_cron.py + crontab).
# GAME_5M_RECOVERY_D4A_STATS_WINDOW_DAYS=21
# GAME_5M_RECOVERY_D4A_STATS_K_BARS=3,6,9,12
# GAME_5M_RECOVERY_D4A_STATS_MIN_DEFER=2
# GAME_5M_RECOVERY_D4A_STATS_JSONL=/app/logs/ml/recovery_d4a_rollup.jsonl
# «Shallow» lookback только для счётчиков TE/gate по 7/14/21… дн. (без второго OHLC в основном окне).
# GAME_5M_RECOVERY_D4A_STATS_SHALLOW_LOOKBACK_DAYS=30
# Пороги числа SELL с recovery gate для подсказки «можно ли сузить окно» (см. window_suggestion в JSON / анализатор).
# GAME_5M_RECOVERY_D4A_STATS_SUFFICIENT_GATE_MIN=5
# GAME_5M_RECOVERY_D4A_STATS_COMFORTABLE_GATE_MIN=10
# Включить те же shallow-поля в GET /api/analyzer (второй лёгкий SELECT по БД).
# GAME_5M_RECOVERY_D4A_STATS_ATTACH_TO_ANALYZER=false

# Momentum BUY: min 5m bars in current RTH session (see recommend_5m). Else optional premarket 1m below.
# GAME_5M_MOMENTUM_MIN_SESSION_BARS=7
# Momentum BUY across “up to 2h” window through prior day: GAME_5M_MOMENTUM_ALLOW_CROSS_DAY_BUY=true
# Early RTH: if few 5m session bars — momentum from premarket 1m (first→last before 9:30 ET). Disable: false
# GAME_5M_EARLY_USE_PREMARKET_MOMENTUM=true
# Premarket momentum threshold for early BUY (%%). Below this premarket drift — no early momentum BUY:
# GAME_5M_PREMARKET_MOMENTUM_BLOCK_BELOW=-2.0
# GAME_5M_PREMARKET_MOMENTUM_BUY_MIN=0.5
# Cron scripts/send_sndk_signal_cron.py: second BUY in DB while position open = add-on. Default forbidden.
GAME_5M_ALLOW_PYRAMID_BUY=false
# Intermediate add-on gate: with ALLOW_PYRAMID_BUY=false, allow a second BUY only when live hanger diagnosis ran and returned no hanger.
# Later this should be replaced by stuck_risk_score / continuation_score gates.
# GAME_5M_ALLOW_PYRAMID_IF_NOT_HANGER=false
# Market bars lookback horizon for cron analytics/replay helpers (days).
# GAME_5M_BAR_HORIZON_DAYS=10
# First RTH hour (session_phase NEAR_OPEN): near daily high, PnL >= min % but below full take — close (fade protection after “chase”).
GAME_5M_SOFT_TAKE_NEAR_HIGH_ENABLED=true
# GAME_5M_SOFT_TAKE_NEAR_HIGH_MIN_PCT=2.0
# GAME_5M_SOFT_TAKE_MAX_PULLBACK_FROM_HIGH_PCT=0.35

# ---- Portfolio game (not in focus: Neutral, Mean Reversion, Momentum, etc.) ----
# Portfolio take-profit (%) when BUY has no take_profit (fallback / Portfolio legacy). 0 = never auto-close on take.
PORTFOLIO_TAKE_PROFIT_PCT=8
# Block new portfolio BUY when CatBoost entry_score below threshold (advisory model; see ML_PORTFOLIO_CATBOOST.md).
PORTFOLIO_CATBOOST_BLOCK_BUY_ON_WEAK=true
PORTFOLIO_CATBOOST_HOLD_BELOW_SCORE=48
# Phase 5: ML-adjusted take at entry (snapshot in context_json) + trailing giveback from peak (daily high).
PORTFOLIO_ML_TAKE_ENABLED=true
PORTFOLIO_ML_TAKE_FACTOR=1.5
PORTFOLIO_ML_TAKE_FLOOR_PCT=4
PORTFOLIO_ML_TAKE_CAP_PCT=18
PORTFOLIO_TRAILING_TAKE_ENABLED=true
PORTFOLIO_TRAILING_MIN_PROFIT_PCT=8
PORTFOLIO_TRAILING_PULLBACK_PCT=3
# Portfolio CatBoost (advisory expected forward return on daily quotes; shown on portfolio cards):
# PORTFOLIO_CATBOOST_ENABLED=false
# PORTFOLIO_CATBOOST_MODEL_PATH=/app/logs/ml/models/portfolio_return_catboost.cbm
# Dispatcher continuous_prod: write .cbm when trigger fires (default on after portfolio gate ready).
# ML_PORTFOLIO_CONTINUOUS_TRAIN=1
# Optional JSONL log of training runs (trend of RMSE/MAE/top-decile hit):
# PORTFOLIO_ML_REPORT_JSONL=/app/logs/ml/logs/portfolio_daily_ml_report.jsonl
#
# ---- ML train readiness (гейты продакшена; dry-run по умолчанию) ----
# ML_READINESS_JSONL=/app/logs/ml/logs/ml_train_readiness.jsonl
# ML_READINESS_TRAIN_MODE=dry_run
# ML_READINESS_TRAIN_MODE=full
# ML_READINESS_GAME5M_AUC_MIN=0.52
# ML_READINESS_PORTFOLIO_RMSE_MAX=0.08
# ML_READINESS_SKIP_GAME5M=0
# ML_READINESS_SKIP_PORTFOLIO=0
#
# ML readiness: train event-reaction в ночном cron включается через docker exec -e ML_READINESS_SKIP_EVENT_REACTION=0
# (см. crontab/lse-docker.crontab); в config.env ниже по умолчанию не гоняется — не ломает overall, если cron без -e.
# ML_READINESS_SKIP_EVENT_REACTION=1
# ML_READINESS_EVENT_REACTION_RMSE_MAX=0.12
# ML_READINESS_EVENT_REACTION_MIN_TRAIN=300
# ---- Unified ML retrain (data-driven; see docs/ML_UNIFIED_RETRAIN_FRAMEWORK.md) ----
# ML_<CONTOUR>_RETRAIN_MIN_NEW_UNITS — train when this many new observations since last apply/train
# ML_<CONTOUR>_RETRAIN_MAX_STALENESS_HOURS — fallback train if no data delta (quality phase)
# ML_<CONTOUR>_RETRAIN_POLL_HOURS — poll cadence / continuous staleness (default 6–168)
# ML_<CONTOUR>_CONTINUOUS_TRAIN=1 — after product gate: train on every apply (min 1 new unit)
# Contours: GAME5M_ENTRY, PORTFOLIO, EVENT_REACTION_REGRESSION, EARNINGS_GRID, OPEN_PATH, MULTIDAY_LR, RECOVERY, GAP_FORECAST
# ML_GAME5M_ENTRY_RETRAIN_MIN_NEW_UNITS=8
# ML_GAME5M_ENTRY_RETRAIN_MAX_STALENESS_HOURS=168
# ML_EARNINGS_GRID_RETRAIN_MIN_NEW_UNITS=3
# ML_OPEN_PATH_RETRAIN_MIN_NEW_UNITS=5
# ML_MULTIDAY_LR_TICKERS_SOURCE=merged
# ML_MULTIDAY_LR_RETRAIN_MIN_NEW_UNITS=20
# ML_RECOVERY_RETRAIN_MIN_NEW_UNITS=20
# ML_GAP_FORECAST_ANALYZE_DAYS=90
# ML_GAP_FORECAST_SUGGEST_COEFS=0
# Legacy aliases: EARNINGS_ML_REFRESH_*, OPEN_PATH_ML_* (see services/ml_contour_refresh.py)
# EARNINGS_ML_REFRESH_APPLY_DATA=1       — каждые 6h: labels + outcomes + earnings_v1 features в БД
# EARNINGS_ML_REFRESH_INCREMENTAL_TRAIN=1 — каждые 6h: перезапись .cbm (classifier + peer spillover)
# Nightly: cron 23:52 run_earnings_ml_refresh.py --full (+ shadow report)
# ML_READINESS_SKIP_EARNINGS_INTELLIGENCE=1
# ML_READINESS_EARNINGS_MIN_SCENARIO_LABELS=8
# ML_READINESS_SCENARIO_MIN_TRAINABLE_ROWS=18
# ML_READINESS_SCENARIO_MIN_CLASSES=3
# ML_READINESS_SCENARIO_MIN_CLASS_SAMPLES=2
# ML_READINESS_SCENARIO_MIN_VALID=4
# ML_READINESS_SCENARIO_MAX_SYMBOLS_WITHOUT_LABELS=12
# ML_READINESS_SCENARIO_MAX_HINTS_PENDING=3
# ML_READINESS_SCENARIO_MAX_MISSING_EXTRACT=8
# ML_READINESS_SCENARIO_MAX_LABEL_NO_FEATURES=0
# ML_READINESS_SCENARIO_MAX_SPARSE_CLASSES=2
# ML_READINESS_PEER_SPILLOVER_MIN_ROWS=100
# ML_READINESS_PEER_SPILLOVER_MIN_EVENTS=10
# ML_READINESS_PEER_SPILLOVER_MIN_TRAINABLE_ROWS=80
# ML_READINESS_PEER_SPILLOVER_MIN_TRAIN=80
# ML_READINESS_PEER_SPILLOVER_RMSE_MAX=0.15
# ML_READINESS_PEER_SPILLOVER_MIN_SIGN_ACCURACY=0.5
# ML_READINESS_PEER_SPILLOVER_MIN_PEER_SAMPLES=2
# ML_READINESS_PEER_SPILLOVER_MAX_SOURCES_WITHOUT_ROWS=8
# ML_READINESS_PEER_SPILLOVER_MAX_COLD_PEERS=15
# ML_READINESS_PEER_SPILLOVER_MAX_GRAPH_PEERS_MISSING=10
# EVENT_REACTION_CATBOOST_MODEL_PATH=/app/logs/ml/models/event_reaction_forward5d_catboost.cbm
# Inference: services/event_reaction_catboost_signal.py, guards — event_reaction_entry_guards.py
# EVENT_REACTION_CATBOOST_ENABLED=false
# EVENT_REACTION_BLOCK_BUY_ON_WEAK=false
# EVENT_REACTION_HOLD_BELOW_SCORE=48
# EVENT_REACTION_ENTRY_WINDOW_DAYS=14
# Анализатор LLM: не дублировать LLM_COMPARE_MODELS (иначе зависание на минуты)
# ANALYZER_LLM_SKIP_MODEL_COMPARE=true
# Анализатор LLM: по умолчанию та же модель/base, что OPENAI_MODEL (или ANTHROPIC_MODEL) — см. resolve_analyzer_llm_base_model.
# Для Claude через ProxyAPI достаточно OPENAI_MODEL=claude-sonnet-4-6 (нормализация на openai.api.proxyapi.ru/v1).
# Переопределение только при необходимости:
# ANALYZER_LLM_MODEL=
# ANALYZER_LLM_BASE_URL=
# Секции отчёта (API): core,strategy,exits,catboost,game5m_extra,ml_arbiters,recovery — по умолчанию light=1 → core,strategy,exits
# GAME_5M: при FUSION=none модель только добавляет catboost_entry_proba_good (правила входа те же).
#   hold_if_buy_below_p — осторожно: BUY/STRONG_BUY→HOLD если P < порога (docs/GAME_5M_CATBOOST_FUSION.md).
# GAME_5M_CATBOOST_ENABLED=true
# GAME_5M_CATBOOST_FUSION=hold_if_buy_below_p
# GAME_5M_CATBOOST_HOLD_BELOW_P=0.45
# Portfolio: advisory на карточках/API; сделки не открывает (docs/ML_PORTFOLIO_CATBOOST.md).
# PORTFOLIO_CATBOOST_ENABLED=true
# Ожидаемый edge / издержки для портфельных фич (bps); services/portfolio_ml_features.py
# PORTFOLIO_ML_MIN_EDGE_BPS=
# PORTFOLIO_ML_TRANSACTION_COST_BPS=
# Event reaction dataset: только KB с kb.ts >= даты (эра проекта); build_event_reaction_dataset --kb-since или пусто = без фильтра
# EVENT_REACTION_KB_SINCE=2026-02-01
# Event reaction CatBoost: мин. строк для попытки обучения (CLI --min-rows перекрывает, если задан; иначе этот порог)
# EVENT_REACTION_TRAIN_MIN_ROWS=10
# EVENT_REACTION_LABEL_THRESHOLD_LOG=
# Порог меток UP/DOWN/FLAT в log-пространстве (минимальный «пол» для vol_scaled). См. docs/ML_GLOSSARY_RU.md §4.4
# Rule UP/DOWN/FLAT threshold: fixed (фиксированный) | vol_scaled (масштаб по vol, default max(edge, k*vol_10d_log_ret_std)).
# EVENT_REACTION_LABEL_THRESHOLD_MODE=vol_scaled
# EVENT_REACTION_LABEL_VOL_K=1.5
# Dataset version for train_event_reaction_catboost / run_ml_train_readiness_cron.
# Product advisory: v0_expanded_baseline; nightly cron 23:36–37 leaves most rows on quotes_regime_earnings_v1.
# EVENT_REACTION_DATASET_VERSION=v0_expanded_baseline
# Feature builder для backfill и train_event_reaction_catboost (train auto-fallback если в БД другая версия):
# quotes_mvp_1 | quotes_regime_v1 | quotes_regime_earnings_v1 (рекомендуется для v0_expanded_baseline после cron 23:37)
# EVENT_REACTION_FEATURE_BUILDER_VERSION=quotes_regime_earnings_v1
# Strategy defaults used at BUY entry. Visible in /parameters because these lines are uncommented.
# Override order: code fallback < these config values < DB strategy_parameters.
PORTFOLIO_MOMENTUM_STOP_LOSS_PCT=3
PORTFOLIO_MOMENTUM_TAKE_PROFIT_PCT=10
PORTFOLIO_MEAN_REVERSION_STOP_LOSS_PCT=5
PORTFOLIO_MEAN_REVERSION_TAKE_PROFIT_PCT=4
PORTFOLIO_VOLATILE_GAP_STOP_LOSS_PCT=7
PORTFOLIO_VOLATILE_GAP_TAKE_PROFIT_PCT=15
PORTFOLIO_GEOPOLITICAL_BOUNCE_STOP_LOSS_PCT=5
PORTFOLIO_GEOPOLITICAL_BOUNCE_TAKE_PROFIT_PCT=4
# Neutral normally has no strategy take/stop. Leave empty unless you want Neutral BUYs to carry thresholds.
PORTFOLIO_NEUTRAL_STOP_LOSS_PCT=
PORTFOLIO_NEUTRAL_TAKE_PROFIT_PCT=

# Premarket (scripts/premarket_cron.py): Telegram alert (gap, minutes to open).
PREMARKET_ALERT_TELEGRAM=false
# In premarket — add 5m forecast block for game tickers.
PREMARKET_ENTRY_PREVIEW_5M=true
# Stress tickers (forex, oil): gap below threshold → alert to close before open.
PREMARKET_STRESS_TICKERS=GBPUSD=X,EURUSD=X,CL=F
PREMARKET_STRESS_GAP_PCT=-1.5
PREMARKET_STRESS_ALERT_FRIDAY_ONLY=true
# Макро для GAME_5m: VIX↑ / Forex↓ / нефть↑ → risk-off; VIX↓ / Forex↑ / нефть↓+спокойный VIX → гэп вверх
PREMARKET_STRESS_USE_MACRO_RISK=true
PREMARKET_FAVORABLE_ALERT_TELEGRAM=true
PREMARKET_STRESS_ALERT_ON_CAUTION=false
GAME_5M_MACRO_RISK_ENABLED=true
# Если true: крон 5m не открывает новый long при entry_advice=AVOID и пустой позиции (совпадает с карточкой «Вход»). Докуп при открытой позиции не блокируется.
GAME_5M_MACRO_BLOCK_NEW_BUY_ON_AVOID=false
GAME_5M_MACRO_FOREX_TICKERS=GBPUSD=X,EURUSD=X
GAME_5M_MACRO_VIX_TICKER=^VIX
GAME_5M_MACRO_OIL_TICKER=CL=F
# Equity benchmark gaps in technical payload (macro_indicators + ndx_gap_pct / spy_gap_pct).
GAME_5M_MACRO_EQUITY_INDEX_TICKERS=^NDX,SPY
GAME_5M_MACRO_FOREX_GAP_AVOID_PCT=-1.0
GAME_5M_MACRO_FOREX_GAP_FAVORABLE_PCT=0.5
GAME_5M_MACRO_VIX_GAP_AVOID_PCT=1.5
GAME_5M_MACRO_VIX_GAP_FAVORABLE_PCT=-1.0
GAME_5M_MACRO_OIL_GAP_STRESS_UP_PCT=2.0
GAME_5M_MACRO_OIL_GAP_FAVORABLE_DOWN_PCT=-1.5
GAME_5M_MACRO_VIX_CALM_MAX_FOR_OIL_FAV=1.0
# В макро-алерте Telegram — гэп и цена премаркета по каждому тикеру GAME_5m (get_tickers_game_5m)
GAME_5M_MACRO_INCLUDE_GAME_5M_GAPS_IN_TELEGRAM=true
# Лог pred_sector + pred_ticker (v2) vs open_gap: game5m_gap_forecast_daily; арбитр game5m_gap_forecast_arbiter (контур gap_forecast)
# Сухой остаток: predict open gap ТОГО ЖЕ trade_date в PRE_MARKET (с текущим PM), не следующего дня. Cron → БД/Telegram; веб → live.
GAME_5M_GAP_FORECAST_LOG_ENABLED=true
# Прогноз гэпа на open по тикеру GAME_5m (OLS v2: сектор+макро; blend с премаркетом)
GAME_5M_TICKER_OPEN_GAP_PREDICT_ENABLED=true
GAME_5M_TICKER_OPEN_GAP_MODEL_VERSION=v2_sector_premarket_blend
GAME_5M_TICKER_OPEN_GAP_PREDICT_MIN_DAYS=25
GAME_5M_TICKER_OPEN_GAP_PREMARKET_BLEND_WEIGHT=0.45
GAME_5M_TICKER_OPEN_GAP_PREMARKET_BLEND_MIN_ABS=1.0
# Pooled model artifact trained from game5m_gap_forecast_daily; fallback remains ticker OLS -> sector proxy.
GAME_5M_PREMARKET_GAP_POOLED_ENABLED=true
# GAME_5M_PREMARKET_GAP_MODEL_PATH=/app/logs/ml/models/premarket_gap/pooled_gap_model.json
GAME_5M_PREMARKET_GAP_MODEL_MIN_ROWS=60
GAME_5M_PREMARKET_GAP_MODEL_L2=5.0
# v2: scale premarket feature (stronger PM → open link); retrain via train_premarket_gap_model.py
GAME_5M_PREMARKET_GAP_PM_FEATURE_SCALE=2.5
# auto=pick baseline until ML beats it on rolling MAE; baseline|ml|blend
GAME_5M_OPEN_GAP_FORECAST_POLICY=auto
GAME_5M_OPEN_GAP_FORECAST_BLEND_ML_WEIGHT=0.35
# Прогноз величины гэпа сектора (OLS SMH): карточки, context_json, премаркет-Telegram. Коэфф. — analyze_macro_gap_indicators; арбитр: macro_predicted_sector_gap
GAME_5M_MACRO_PREDICT_SECTOR_GAP_ENABLED=true
GAME_5M_MACRO_SECTOR_PROXY=SMH
GAME_5M_MACRO_PREDICT_CONST=0.3867
GAME_5M_MACRO_PREDICT_BETA_VIX=-0.1842
GAME_5M_MACRO_PREDICT_BETA_GBPUSD=-0.6266
GAME_5M_MACRO_PREDICT_BETA_EURUSD=0.1921
GAME_5M_MACRO_PREDICT_BETA_CL=0.1123
# Cron log errors → Telegram (scripts/cron_watchdog.py).
CRON_WATCHDOG_TELEGRAM=false
# Порог «старых» логов для алерта (часы); см. scripts/cron_watchdog.py
# CRON_WATCHDOG_MAX_AGE_HOURS=

# ---- Portfolio game (daily strategies; not in focus — main effort on 5m) ----
# Pause portfolio trading: TRADING_CYCLE_ENABLED=false or unset — trading_cycle_cron and /api/execute skip trades. /portfolio, /recommend, /prompt_entry portfolio are read-only.
# Важно: переменная окружения процесса TRADING_CYCLE_ENABLED перекрывает строку в файле (config_loader.get_config_value). Уберите false из docker-compose environment, если в config.env стоит true.
TRADING_CYCLE_ENABLED=false
# LLM в trading_cycle_cron (ШАГ 3 portfolio_fusion — HTTP к Anthropic/OpenAI): по умолчанию выключено (не задавать или false).
# Включить явно: TRADING_CYCLE_USE_LLM=true. Ручной /api/execute по-прежнему может использовать LLM (см. ExecutionAgent.run_for_tickers).
# TRADING_CYCLE_USE_LLM=true
# Safety guard: portfolio BUY is blocked outside regular NYSE session by default.
# Emergency override only; normal value is false.
# TRADING_CYCLE_ALLOW_OFFHOURS_BUY=false
# Tickers for KB and news ingest (Investing.com): FAST + MEDIUM + LONG.
# MEDIUM/LONG checked vs FAST correlation (scripts/check_medium_long_correlation_with_fast.py).
# Names without solid correlation to FAST are deferred — add here when quotes exist.
# Medium: semis / OEM / PLTR etc. for KB and analysis (not 5m game unless also in TICKERS_FAST). Chef list minus megacaps → LONG.
TICKERS_MEDIUM=ALAB,TER,AMD,ANET,INTC,DELL,AVGO,ORCL,PLTR
# Long: megacap tape (MSFT, META, GOOGL, AMZN, NVDA) + forex, commodities, VIX. Overlap with correlation list is OK for news ingest.
TICKERS_LONG=MSFT,META,GOOGL,AMZN,NVDA,ANET,INTC,DELL,ALAB,AVGO,ORCL,PLTR,AMD,SNDK,GBPUSD=X,GC=F,^VIX,CL=F,BZ=F
# OIL_TICKER=CL=F
# Explicit list for trading_cycle_cron (empty or unset = MEDIUM+LONG; cron when TRADING_CYCLE_ENABLED=true)
# TRADING_CYCLE_TICKERS=
# DASHBOARD_WATCHLIST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT,META,AMZN

# ============================================
# Web Interface Configuration
# ============================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Журнал применённых правок тюнинга GAME_5M (UI анализатора); опционально.
# GAME5M_TUNING_LEDGER=
# /parameters: keys = uncommented lines in this file (except secrets in config_loader blocklist).
# Plus GAME_5M_TAKE_PROFIT_PCT_<T> / GAME_5M_MAX_POSITION_DAYS_<T> per TICKERS_FAST.
# Restart after web edits; empty — `docker compose restart lse` (docker must be in PATH; else exit 127).
# Example with full path: RESTART_CMD=/usr/bin/docker compose -f /path/to/lse/docker-compose.yml restart lse
RESTART_CMD=

# ============================================
# Trade effectiveness analyzer — 5m OHLC (не live-игра)
# ============================================
# Игра и get_decision_5m всегда через yfinance (fetch_5m_ohlc). Графики веба могут брать market_bars_5m.
# Анализатор: по умолчанию тот же приоритет, что и игра — yfinance, при пустом ответе fallback Postgres.
# Чтобы снова сначала БД (воспроизводимость офлайн-отчёта): раскомментируйте и выставьте postgres_first.
# TRADE_ANALYZER_5M_OHLC_SOURCE=postgres_first

# ============================================
# Analyzer autotune (evolutionary tuning)
# ============================================
# Idea: one change → wait window → compare → next.
# Default APPLY off: script only picks candidate and writes local/autotune_state.json.
# Run: python3 scripts/analyzer_autotune.py --days 5 --url http://127.0.0.1:8080/api/analyzer
ANALYZER_AUTOTUNE_APPLY=0
# New trades needed after apply before pending is marked ready_for_review.
ANALYZER_AUTOTUNE_MIN_TRADES=8
# Deny keys (comma-separated); by default do not touch cron keys.
ANALYZER_AUTOTUNE_DENY_KEYS=GAME_5M_SIGNAL_CRON_MINUTES
# Selection preference (comma-separated prefixes): per-ticker cap first, then factor.
ANALYZER_AUTOTUNE_PREFER_PREFIXES=GAME_5M_TAKE_PROFIT_PCT_,GAME_5M_TAKE_MOMENTUM_FACTOR
# State file path (if unset — local/autotune_state.json).
# ANALYZER_AUTOTUNE_STATE_PATH=/var/lib/lse/autotune_state.json
# Снимки отчёта анализатора / сравнение прогонов (scripts/snapshot_analyzer_report.py, analyzer_autotune)
# ANALYZER_SNAPSHOT_DIR=
# ANALYZER_SNAPSHOT_URL=http://127.0.0.1:8000/api/analyzer
# Состояние последнего прогона анализатора (services/trade_effectiveness_analyzer.py)
# ANALYZER_STATE_PATH=
# Исключить ключи из кандидатов автотюнинга (через запятую)
# ANALYZER_TUNE_SKIP_KEYS=

# ============================================
# Daily Game5M ML pipeline (scripts/run_daily_game5m_ml_pipeline.py)
# ============================================
# DAILY_ML_OUT_DIR=/app/logs/ml
# DAILY_ML_REPORT_JSONL=/app/logs/ml/logs/game5m_daily_ml_report.jsonl
# DAILY_ML_MIN_CATBOOST_ROWS=

# ============================================
# Daily Recovery ML pipeline (scripts/run_daily_game5m_recovery_pipeline.py)
# ============================================
# DAILY_RECOVERY_DAYS=30
# DAILY_RECOVERY_HORIZON_MINUTES=120
# DAILY_RECOVERY_SKIP_TRAIN=false
# DAILY_RECOVERY_EXPORT_ONLY=false
# DAILY_RECOVERY_REPORT_JSONL=/app/logs/ml/logs/game5m_recovery_daily_report.jsonl

# ============================================
# News: sources, keys, tuning (knowledge_base)
# ============================================
# Map (names match NYSE where noted — one key can live in both config.env files):
#   Secrets:     NEWSAPI_KEY | ALPHAVANTAGE_KEY | MARKETAUX_API_KEY  (optional: NYSE_CONFIG_PATH → merge nyse/config.env)
#   Macro/aggregators: NewsAPI (+NEWSAPI_*), Alpha Vantage (+ALPHAVANTAGE_*, EARNINGS_*)
#   Ticker NYSE-style: Yahoo (no key) + Marketaux — TICKER_NEWS_* and MARKETAUX_API_KEY
#   Investing.com: INVESTING_NEWS_* (HTML feed); calendar — JSON API only (like nyse); INVESTING_CALENDAR_USE_HTML=true — legacy HTML
#   Central bank RSS: no keys (URLs in services/rss_news_fetcher.py)
# API limits: docs/NEWS_LIMITS.md. Ingest: scripts/fetch_news_cron.py (--mode all|core|core-fast|newsapi|investing|tickers).
#
# Knowledge base: save only TICKERS_* + MACRO (true) or all incoming from Alpha Vantage / LLM news (false — default).
# KB_INGEST_TRACKED_TICKERS_ONLY=false
#
# --- News volume for LLM / decisions (see docs/NEWS_LIMITS.md) ---
# Typical limits: NewsAPI developer ~100 HTTP requests/day — each PAGE = 1 request; macro + equity = 2+ requests per fetch_news_cron --mode newsapi run.
# Alpha Vantage free ~25 requests/day — do not enable extra economic/technical without need.
# Analyst/bot lookback (hours of KB news): default 336 h = 14 days.
# KB_NEWS_LOOKBACK_HOURS=336

# --- NewsAPI.org (key name matches NYSE: NEWSAPI_KEY) ---
# NewsAPI.org — news aggregator (free tier ~100 requests/day — each page = one request)
# NEWSAPI_KEY=
# Single combined macro query instead of five separate (default true). false — old mode (burns quota).
# NEWSAPI_MACRO_SINGLE_QUERY=true
# Custom query instead of built-in DEFAULT_MACRO_QUERY (long OR string); can add geopolitics: … OR (Ukraine OR Taiwan OR sanctions OR Gaza)
# NEWSAPI_MACRO_QUERY=
# Pages (~100 articles each) per macro run (1 = saves quota). Max 5. For more flow: 2–3.
# NEWSAPI_MAX_PAGES=2
# /everything "from" depth (days back). Code: up to 30. For two-week decisions: 14.
# NEWSAPI_DAYS_BACK=14
# Second query by portfolio tickers (OR symbols from EARNINGS_TRACK_TICKERS or TICKERS_FAST). +N pages see NEWSAPI_EQUITY_MAX_PAGES.
# NEWSAPI_FETCH_EQUITY=true
# NEWSAPI_EQUITY_MAX_PAGES=2
# Explicit ticker list for equity query (empty = EARNINGS_TRACK_TICKERS or TICKERS_FAST)
# NEWSAPI_EQUITY_TICKERS=SNDK,MU,MSFT,LITE,ALAB,TER
# After 429 pause NewsAPI N hours (cooldown file in logs). Reset: delete file.
# NEWSAPI_COOLDOWN_AFTER_429_HOURS=12
# After 426 Upgrade Required (plan/endpoint) — pause to avoid log spam every cron.
# NEWSAPI_COOLDOWN_AFTER_426_HOURS=24
# NEWSAPI_COOLDOWN_FILE=/app/logs/.newsapi_cooldown_until

# --- Alpha Vantage (key name matches NYSE: ALPHAVANTAGE_KEY) ---
# Alpha Vantage — Earnings Calendar and News Sentiment
# ALPHAVANTAGE_KEY=
# Free plan: 25 requests/day. Economic and technical indicators burn quota — keep off unless needed:
# ALPHAVANTAGE_FETCH_ECONOMIC=false
# ALPHAVANTAGE_FETCH_TECHNICAL=false
# (defaults both false; then Earnings + News only.)
# Do not save Earnings Calendar to KB (“Earnings report for X” noise). Cleanup: scripts/cleanup_calendar_noise.py
# EARNINGS_CALENDAR_SAVE=false
# Tickers: Alpha Vantage earnings calendar (when EARNINGS_CALENDAR_SAVE=true), NewsAPI equity fallback, scripts/fetch_news_cron.py earnings list.
# EARNINGS_TRACK_TICKERS=MSFT,SNDK,MU,LITE,ALAB,TER
# Timeouts / retries (read via os.environ in services/alphavantage_fetcher.py)
# ALPHAVANTAGE_TIMEOUT=90
# ALPHAVANTAGE_MAX_RETRIES=3
# ALPHAVANTAGE_RETRY_DELAY=10
# ALPHAVANTAGE_MIN_DELAY_SEC=1
# Throttle between tickers / indicators / after HTTP errors (seconds)
# ALPHAVANTAGE_DELAY_AFTER_ERROR=15
# ALPHAVANTAGE_DELAY_BETWEEN_TICKERS=15
# ALPHAVANTAGE_DELAY_BETWEEN_INDICATORS=13
# Use system HTTP proxy for Alpha Vantage (set false if SOCKS/proxy breaks requests)
# ALPHAVANTAGE_USE_SYSTEM_PROXY=false

# --- Yahoo Finance: календарь earnings (yfinance, без ключа; дополняет Alpha Vantage) ---
# Включено по умолчанию в fetch_news_cron --mode core-fast|core|all.
# YFINANCE_EARNINGS_CALENDAR_SAVE=true
# Список тикеров (пусто = EARNINGS_TRACK_TICKERS)
# YFINANCE_EARNINGS_TICKERS=
# Сколько последних дат earnings на тикер (1–40)
# YFINANCE_EARNINGS_LIMIT=12
# Пауза между запросами к Yahoo (сек)
# YFINANCE_EARNINGS_DELAY_SEC=1.0

# Motley Fool transcript auto-probe (sync): cooldown hours after HTTP 429 (autoprep enables Fool by default; use --no-auto-fool to skip)
# FOOL_TRANSCRIPT_COOLDOWN_AFTER_429_HOURS=6
# EARNINGS_FOOL_PROBE_DAY_WINDOW=1
# EARNINGS_FOOL_MAX_PROBE=18

# --- Marketaux (key name matches NYSE: MARKETAUX_API_KEY; supplements Yahoo, does not replace) ---
# Used in fetch_news_cron --mode tickers | core | all (TickerNews layer).
# MARKETAUX_API_KEY=
# Avoid duplicating key in two files: merge nyse/config.env (only fills empty LSE keys).
# NYSE_CONFIG_PATH=/home/you/projects/nyse/config.env

# --- Ticker news (NYSE-style): Yahoo (yfinance) + Marketaux merge ---
# Ticker list for ticker news. Empty = TICKERS_FAST.
# TICKER_NEWS_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT
# News window (hours), default 48.
# TICKER_NEWS_LOOKBACK_HOURS=48
# Yahoo: how many headlines per ticker, default 40.
# TICKER_NEWS_MAX_PER_TICKER=40
# knowledge_base exchange label (default NYSE).
# TICKER_NEWS_EXCHANGE=NYSE

# --------------------------------------------
# Investing.com News (stock-market-news feed)
# --------------------------------------------
# How many headlines to scan from feed per run (keyword filter; not all land in KB). 10–80.
# INVESTING_NEWS_MAX_ARTICLES=50
# Tickers — from TICKERS_FAST + MEDIUM + LONG (incl. ^VIX, commodities BZ=F, GC=F). Keywords are built-in
# (SNDK, AMD, CL=F, BZ=F, GC=F, ^VIX, etc.). Optional extra (adds to built-in, does not replace):
# Format: TICKER:word1,word2;OTHER:word3 (comma separates words; spaces in phrase allowed, e.g. "Brent Oil")
# INVESTING_NEWS_TICKER_KEYWORDS=SNDK:Citron,short;AMD:Advanced Micro Devices;BZ=F:Brent Oil;Brent;^VIX:VIX,volatility
# On 403 Forbidden set HTTP(S) proxy (browser or residential).
# Only http:// or https:// — socks5:// when loading config into env breaks model load (vector_kb).
# If no proxy — comment out or remove the line.
# INVESTING_NEWS_PROXY=
# HTML feed read timeout (sec), one retry on timeout. Default 55.
# INVESTING_NEWS_TIMEOUT=55
# true — drop article if headline matched a ticker not in KB list (legacy; many silent drops).
# false — save such rows as MACRO (default).
# INVESTING_NEWS_STRICT_TRACKED_ONLY=false

# --- KB /news: NYSE-style REG cluster (TF-IDF) for draft_impulse / gate (env names match nyse repo) ---
# NYSE_REGIME_CLUSTER=1
# NYSE_REGIME_CLUSTER_THRESHOLD=0.88
# NYSE_REGIME_CLUSTER_EMBED=tfidf
# (OpenAI embeddings not wired in LSE — if openai requested, code forces TF-IDF)

# --- Investing.com Economic Calendar (macro KB), like nyse — API only ---
# JSON API without key: services/investing_calendar_api.py. No auto-fallback to HTML.
# true — legacy HTML scrape by region only (do not enable unless API unavailable).
# INVESTING_CALENDAR_USE_HTML=false
# Use system proxy for calendar requests: INVESTING_CALENDAR_USE_SYSTEM_PROXY=true (PySocks for socks).
# Save HTML snapshots for debugging failed calendar parses (1/true/yes)
# INVESTING_CALENDAR_DEBUG_HTML=false

# Note: LLM news (USE_LLM_NEWS etc.) are not invoked from fetch_news_cron; cron uses RSS, NewsAPI, Alpha Vantage, TickerNews (Yahoo+Marketaux), Investing.
# USE_LLM_NEWS=false
# Cooldown between LLM news runs (hours); default in code 168 (7 days)
# LLM_NEWS_COOLDOWN_HOURS=168

# ============================================
# Telegram Bot Configuration
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_SIGNAL_CHAT_ID=
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_WEBHOOK_URL=https://your-service.run.app/webhook
# Proxy for api.telegram.org if blocked: http://host:port or https://...
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# Signal broadcasts (send_sndk_signal_cron, premarket): comma-separated chats or single TELEGRAM_SIGNAL_CHAT_ID
# TELEGRAM_SIGNAL_CHAT_IDS=
# TELEGRAM_SIGNAL_CHAT_ID=
# Mentions in messages (e.g. @username): TELEGRAM_SIGNAL_MENTIONS=@user1 @user2
# Dashboard chat (send_dashboard_cron): TELEGRAM_DASHBOARD_CHAT_ID=
# /closed and /closed_impulse report limits (HTML file to chat): default count and max N in command
# TELEGRAM_CLOSED_REPORT_DEFAULT=25
# TELEGRAM_CLOSED_REPORT_MAX=200
# Web /reports/closed and Excel: row cap (not below TELEGRAM_CLOSED_REPORT_MAX). Example: 500
# WEB_CLOSED_REPORT_MAX=500

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_DIR=logs

