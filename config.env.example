# ============================================
# Конфигурация LSE Trading System (шаблон)
# ============================================
# Скопируйте этот файл в config.env и подставьте свои ключи (LLM, новости, Telegram и т.д.).
# Отдельная настройка не нужна: приложение читает config.env при старте; отсутствующие ключи — соответствующий источник отключён или используется дефолт.

# ============================================
# GitHub (опционально)
# ============================================
# Personal access token: скрипты/API, которые читают GITHUB_TOKEN из окружения.
# Репозиторий tradenews: push — ./tradenews/scripts/push_github_from_config_env.sh (сначала tradenews/config.env, затем этот файл lse).
# Опционально дублируйте токен в tradenews/config.env — см. tradenews/config.env.example.
# Иначе для git удобнее credential helper — см. docs/DEPLOY.md.
# GITHUB_TOKEN=ghp_your_token_here

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/lse_trading

# ============================================
# OpenAI/ProxyAPI Configuration
# ============================================
# Ключ ProxyAPI (или прямой OpenAI). Для прямого OpenAI можно задать OPENAI_GPT_KEY и OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_proxyapi_key_here
# Опционально: ключ для прямого доступа к OpenAI (gpt-4o). Проверка: python scripts/check_openai_gpt_key.py (локально может быть 403 по региону — на сервере тот же ключ обычно работает)
# OPENAI_GPT_KEY=sk-...
# Прокси: https://api.proxyapi.ru/openai/v1. Прямой OpenAI: https://api.openai.com/v1 (на сервере в разрешённом регионе)
# OpenRouter (через proxyapi): https://api.proxyapi.ru/openrouter/v1 — тогда OPENAI_MODEL = id из OpenRouter (например anthropic/claude-sonnet-4.6)
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT=60
# chat.completions: gpt-5.x / o1 / o3 / o4 — в коде подставляется max_completion_tokens вместо max_tokens (требование API).
# Принудительно: OPENAI_CHAT_USE_MAX_COMPLETION_TOKENS=1|0 если прокси ведёт себя иначе.
# Анализатор сделок /api/analyzer?use_llm=1: лимит completion для большого JSON-ответа (по умолчанию 4096 / фокус 6144).
# ANALYZER_LLM_MAX_COMPLETION_TOKENS=8192
# Сравнение нескольких моделей: через запятую "model" или "provider|model" (openai, anthropic, google)
# Пример: gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# LLM_COMPARE_MODELS=gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# Подбор модели: docs/LLM_MODEL_SELECTION.md

# ============================================
# Embedding Configuration (для векторной БЗ — Vector KB)
# ============================================
# Локальная модель (sentence-transformers / Hugging Face). Используется, если не включены облачные эмбеддинги.
# Примеры: intfloat/multilingual-e5-base (мультиязычный, 768 dim), sentence-transformers/all-mpnet-base-v2
HF_MODEL_NAME=intfloat/multilingual-e5-base

# Облачные эмбеддинги (если локальная модель даёт Bus error / core dumped):
# USE_OPENAI_EMBEDDINGS=true
# (тот же OPENAI_API_KEY и OPENAI_BASE_URL что для GPT-4o; модель text-embedding-3-small, 768 dim)
# Альтернатива — Gemini: USE_GEMINI_EMBEDDINGS=true, GEMINI_API_KEY=...

# ============================================
# Sentiment Analysis Configuration
# ============================================
# При добавлении новостей (CLI, CSV, веб): считать sentiment через LLM сразу
SENTIMENT_AUTO_CALCULATE=true
# Кто считает sentiment новостей: llm = платный LLM (OPENAI_MODEL, даёт ещё insight); transformers = бесплатная локальная модель (без insight).
# SENTIMENT_METHOD=transformers
SENTIMENT_METHOD=llm
# При SENTIMENT_METHOD=transformers — модель HuggingFace (по умолчанию FinBERT для финансовых текстов).
# SENTIMENT_MODEL=ProsusAI/finbert
# USE_LLM — применение LLM: при false не используем LLM; иначе — да.
# Управляет: аналитик в Telegram-боте (/signal, /recommend, /ask, /prompt_entry), trading_cycle_cron (ExecutionAgent),
# а также блок «С учётом корреляции (LLM)» в отчётах game_5m (/pe_5m, /prompt_entry 5m, /recommend5m).
# крон add_sentiment_to_news_cron (backfill sentiment по новостям). В дальнейшем можно хранить в БД (strategy_parameters GLOBAL).
# USE_LLM=false
USE_LLM=true

# ============================================
# Trading Configuration
# ============================================
# Начальный капитал и кэш — в local/risk_limits.json (risk_capacity.total_capital_usd).
# Чтобы увеличить кэш: отредактировать total_capital_usd и в БД: UPDATE portfolio_state SET quantity = <сумма> WHERE ticker = 'CASH';
COMMISSION_RATE=0
# Порог стоп-лосса портфеля: при падении цены ниже этого уровня (лог-доходность) позиция закрывается. 0.95 ≈ −5%
STOP_LOSS_LEVEL=0.95
# Стоп-лосс портфеля: true = проверять по STOP_LOSS_LEVEL; false = отключён (в логах — предупреждение, закрывается только по тейку).
# Можно переопределить в БД: strategy_parameters (GLOBAL) — PORTFOLIO_STOP_LOSS_ENABLED, STOP_LOSS_LEVEL.
PORTFOLIO_STOP_LOSS_ENABLED=true
# Автовыходы портфеля только по тейку (true = игнорировать стоп и прочие выходы, кроме take-profit).
PORTFOLIO_EXIT_ONLY_TAKE=false
# Песочница: проскальзывание при продаже (%). Реальная цена исполнения может быть хуже последней котировки (цена просела). 0 = отключено, 0.3 = консервативно.
# SANDBOX_SLIPPAGE_SELL_PCT=0.3

# ============================================
# Игры: быстрая (5m) и портфельная
# ============================================
# Фокус: быстрая игра 5m (daily на волатильных стоках). Портфельная игра пока не актуальна — все силы на 5m.
# Корреляция: учитываем «все со всеми» — торгуемые 5m + контекст (фон MSFT/META/AMZN, индикаторы NVDA, SMH, QQQ, VIX, нефть, forex).
# Cron: GAME 5m — send_sndk_signal_cron.py. Портфель — trading_cycle_cron.py (опционально).
# См. docs/TICKER_GROUPS.md

# ---- Быстрая игра (5m): прогнозы для вступления — приоритет; трейдер играет сам, информация по возможности раньше ----
# Целевые стоки для daily (Alex: SNDK, NBIS — лидеры; ASML, MU — AI; LITE, CIEN — волатильные)
# Добавление MSFT в FAST: проверка корреляций по парам с Microsoft (ищем тикер-«затык» по NaN)
TICKERS_FAST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT
# Тикеры, по которым крон запускает игру 5m (вход/выход). Пусто = все из TICKERS_FAST.
GAME_5M_TICKERS=
# Контекст для корреляции «все со всеми»: фон + индикаторы волатильности (^VIX) + геополитика (нефть CL=F, золото GC=F) + forex. Не торгуем ими в 5m.
GAME_5M_CORRELATION_CONTEXT=MSFT,META,AMZN,NVDA,SMH,QQQ,TLT,^VIX,CL=F,GC=F,GBPUSD=X
# Матрица корреляции для 5m (крон, LLM): по умолчанию игра 5m + портфель (/corr) + контекст выше. Только игра+контекст: GAME_5M_CORRELATION_EXCLUDE_PORTFOLIO=true
# GAME_5M_CORRELATION_EXCLUDE_PORTFOLIO=
# Cooldown между рассылками сигнала на вход по одному тикеру (минуты)
GAME_5M_COOLDOWN_MINUTES=120
# Интервал крона send_sndk_signal_cron (минуты): должен совпадать с расписанием crontab (см. setup_cron.sh */N). 1 = чаще проверка выходов/входов.
GAME_5M_SIGNAL_CRON_MINUTES=5
# Пороги технического решения get_decision_5m (RSI/импульс). Было захардкожено в коде — теперь задаётся здесь.
GAME_5M_RSI_STRONG_BUY_MAX=32
GAME_5M_MOMENTUM_STRONG_BUY_MIN=-0.3
GAME_5M_RSI_BUY_MAX=38
GAME_5M_PRICE_TO_LOW5D_MULT_MAX=1.005
GAME_5M_RSI_SELL_MIN=76
GAME_5M_RSI_HOLD_OVERBOUGHT_MIN=68
# Мин. импульс RTH (сессия / премаркет 1m / кросс-дневной) для импульсного BUY; см. recommend_5m.
GAME_5M_RTH_MOMENTUM_BUY_MIN=0.5
GAME_5M_RSI_FOR_MOMENTUM_BUY_MAX=62
GAME_5M_VOLATILITY_WARN_BUY_MIN=0.4
# Выше — «выжидать» вход (CAUTION / не BUY при шуме). См. docs/TRADE_EFFECTIVENESS_ANALYZER.md этап 1.
GAME_5M_VOLATILITY_WAIT_MIN=0.7
# Подтверждение SELL по RSI на N предыдущих барах 5m.
GAME_5M_SELL_CONFIRM_BARS=2
# Стратегия входа 5m: technical | llm. См. docs/GAME_5M_BUY_DECISION_AND_LLM.md §0.
GAME_5M_ENTRY_STRATEGY=technical
# Параметры стратегии 5m (видны в game5m_status, /game5m, API). Анализ убытков: docs/GAME_5M_CLOSED_ANALYSIS.md
# Стоп 5m: false = только тейк / TIME_EXIT / SELL (Alex: без стопа по лоссу)
GAME_5M_STOP_LOSS_ENABLED=false
# Автовыходы 5m только по тейку (true = отключить STOP_LOSS/TIME_EXIT/SELL).
GAME_5M_EXIT_ONLY_TAKE=false
# Внешний Platform POST /game (kerimsrv): после записи входа GAME_5M — в Telegram три списка (notOpened / opened / closed).
# Док: kerimsrv/platform doc.md, образ: kerimsrv/kdoc.md
# PLATFORM_GAME_API_ENABLED=false
# PLATFORM_GAME_API_URL=http://127.0.0.1:8080/game
# PLATFORM_GAME_API_TIMEOUT_SEC=15
GAME_5M_STOP_TO_TAKE_RATIO=0.5
GAME_5M_STOP_LOSS_PCT=1.5
GAME_5M_MAX_POSITION_DAYS=1
# По тикеру (если рост растягивается на 2–4 дня): GAME_5M_MAX_POSITION_DAYS_NBIS=3. Подбор: scripts/suggest_max_position_days_5m.py
# GAME_5M_MAX_POSITION_DAYS_NBIS=3
# Ежедневный пересчёт в suggested_5m_params.json больше не подмешивается в игру автоматически.
# Параметры 5m берутся только из явных GAME_5M_* в этом файле.
# (Ключ оставлен для совместимости; на логику не влияет.)
USE_SUGGESTED_5M_PARAMS=false
GAME_5M_STOP_LOSS_MIN_PCT=0.5
# Потолок тейка (%). Тейк по импульсу: если импульс_2ч >= GAME_5M_TAKE_PROFIT_MIN_PCT — тейк = min(импульс_2ч × factor, потолок); иначе тейк = потолок. Поэтому при импульсе 6% тейк срабатывает на 6%, а не на 7%.
GAME_5M_TAKE_PROFIT_PCT=7
# Импульсы менее этого % не рассматриваем — тейк = потолок (GAME_5M_TAKE_PROFIT_PCT). Иначе тейк от импульса 2ч (Alex: от 4%).
GAME_5M_TAKE_PROFIT_MIN_PCT=4.0
# Пороги по ATR и объёму (пусто = не применять). Оценка: python scripts/estimate_5m_thresholds.py
GAME_5M_MIN_VOLUME_VS_AVG_PCT=
GAME_5M_MAX_ATR_5M_PCT=
# Тейк от импульса 2ч: 1.0 = полный импульс; <1 — консервативнее; >1 — агрессивнее (до min в коде, сейчас max 2.0); итог всё равно min(..., потолок).
GAME_5M_TAKE_MOMENTUM_FACTOR=1.0
# Потолок тейка по тикеру (опционально): SNDK=8 → для SNDK макс. тейк 8%, для остальных — GAME_5M_TAKE_PROFIT_PCT.
# GAME_5M_TAKE_PROFIT_PCT_SNDK=8
# GAME_5M_TAKE_PROFIT_PCT_MU=5
# Последние N минут сессии (до 16:00 ET): плюс >= MIN_PROFIT_PCT → TIME_EXIT (кроме STRONG_BUY).
GAME_5M_SESSION_END_EXIT_MINUTES=30
GAME_5M_SESSION_END_MIN_PROFIT_PCT=0.3
# Guard качества входа (против слабых BUY -> TIME_EXIT в минус): при включении BUY/STRONG_BUY -> HOLD,
# если R:R и/или матожидание ниже порогов. Строки без # нужны для веб-редактора и auto_config_override анализатора.
GAME_5M_ENTRY_QUALITY_GUARD_ENABLED=false
GAME_5M_ENTRY_QUALITY_MIN_RR=1.2
GAME_5M_ENTRY_QUALITY_MIN_EV_PCT=0.0
# Более точный лимит удержания (минуты). Если задан, имеет приоритет над GAME_5M_MAX_POSITION_DAYS.
# GAME_5M_MAX_POSITION_MINUTES=
# GAME_5M_MAX_POSITION_MINUTES_SNDK=720
# GAME_5M_MAX_POSITION_MINUTES_CIEN=720
# Ранний de-risk выход из просадки (TIME_EXIT_EARLY), когда импульс/решение не поддерживают удержание.
# GAME_5M_EARLY_DERISK_ENABLED=false
# GAME_5M_EARLY_DERISK_MIN_AGE_MINUTES=180
# GAME_5M_EARLY_DERISK_MAX_LOSS_PCT=-2.0
# GAME_5M_EARLY_DERISK_MOMENTUM_BELOW=0.0
# Блок LLM-новостей в 5m (см. docs/GAME_5M_NEWS.md); true только при актуальном контексте новостей.
GAME_5M_USE_LLM_NEWS=false
# CatBoost: доп. мнение в get_decision_5m (не меняет правила входа). Зависимости: pip install -r requirements-catboost.txt
# План обучения: docs/ML_GAME5M_CATBOOST.md; скрипт: python scripts/train_game5m_catboost.py
# GAME_5M_CATBOOST_ENABLED=false
# GAME_5M_CATBOOST_MODEL_PATH=local/models/game5m_entry_catboost.cbm
# Мин. закрытых сделок с context_json для обучения (scripts/train_game5m_catboost.py)
# GAME_5M_CATBOOST_MIN_TRAIN_ROWS=60
# Добавить вероятность в reasoning: GAME_5M_CATBOOST_APPEND_REASONING=false
# Слияние CatBoost с тех. решением для входа и LLM (выход из позиции всегда по чистым правилам — technical_decision_core):
#   none — итог = правила (по умолчанию); hold_if_buy_below_p — BUY/STRONG_BUY→HOLD если P < порога и статус CatBoost ok
# GAME_5M_CATBOOST_FUSION=none
# GAME_5M_CATBOOST_HOLD_BELOW_P=0.45

# Импульсный BUY: мин. баров 5m в текущей RTH-сессии (см. recommend_5m). Иначе — опционально премаркет 1m ниже.
# GAME_5M_MOMENTUM_MIN_SESSION_BARS=7
# Импульсный BUY по старому окну «до 2ч» через вчерашний день: GAME_5M_MOMENTUM_ALLOW_CROSS_DAY_BUY=true
# Ранний RTH: если баров 5m сессии мало — импульс по 1m премаркета (первая→последняя до 9:30 ET). Отключить: false
# GAME_5M_EARLY_USE_PREMARKET_MOMENTUM=true
# Порог импульса премаркета для раннего BUY (%%). Ниже этого премаркет-дрейфа — ранний импульсный BUY не даём:
# GAME_5M_PREMARKET_MOMENTUM_BLOCK_BELOW=-2.0
# GAME_5M_PREMARKET_MOMENTUM_BUY_MIN=0.5
# Крон scripts/send_sndk_signal_cron.py: второй BUY в БД при уже открытой позиции = докуп. По умолчанию запрещён.
GAME_5M_ALLOW_PYRAMID_BUY=false
# Первый час RTH (session_phase NEAR_OPEN): цена у дневного high, PnL ≥ мин %, но ниже полного тейка — закрыть (защита от разворота после «погони»).
GAME_5M_SOFT_TAKE_NEAR_HIGH_ENABLED=true
# GAME_5M_SOFT_TAKE_NEAR_HIGH_MIN_PCT=2.0
# GAME_5M_SOFT_TAKE_MAX_PULLBACK_FROM_HIGH_PCT=0.35

# ---- Портфельная игра (пока не в фокусе: Neutral, Mean Reversion, Momentum и т.д.) ----
# Тейк-профит портфеля (%) без явного тейка при входе. 0 = не закрывать по тейку.
PORTFOLIO_TAKE_PROFIT_PCT=0

# Премаркет (scripts/premarket_cron.py): алерт в Telegram (гэп, мин до открытия).
PREMARKET_ALERT_TELEGRAM=false
# В премаркете — блок прогноза 5m по тикерам игры.
PREMARKET_ENTRY_PREVIEW_5M=true
# Стресс по индикаторам (Forex, нефть): гэп ниже порога → алерт закрыть до открытия.
PREMARKET_STRESS_TICKERS=GBPUSD=X,EURUSD=X,CL=F
PREMARKET_STRESS_GAP_PCT=-1.5
PREMARKET_STRESS_ALERT_FRIDAY_ONLY=true
# Ошибки в логах cron → Telegram (scripts/cron_watchdog.py).
CRON_WATCHDOG_TELEGRAM=false

# ---- Портфельная игра (дневные стратегии; пока не в фокусе — все силы на 5m) ----
# Приостановка портфельной игры: TRADING_CYCLE_ENABLED=false или не задан — крон trading_cycle_cron и /api/execute не исполняют сделки. /portfolio, /recommend, /prompt_entry portfolio — только просмотр.
TRADING_CYCLE_ENABLED=false
# Тикеры для KB и сбора новостей (Investing.com): FAST + MEDIUM + LONG.
# MEDIUM/LONG проверены на корреляцию с FAST (скрипт scripts/check_medium_long_correlation_with_fast.py).
# Тикеры без нормальной корреляции с FAST убраны «на потом» — добавляйте в конфиг, когда появятся котировки.
TICKERS_MEDIUM=ALAB,TER,AMD
# Долгие: фон (MSFT, META, AMZN), forex, индикаторы (^VIX), геополитика (CL=F, GC=F). MU в FAST — не дублируем в MEDIUM.
TICKERS_LONG=MSFT,META,AMZN,GBPUSD=X,GC=F,^VIX,CL=F
# OIL_TICKER=CL=F
# Явный список для trading_cycle_cron (пусто или не задан = MEDIUM+LONG; крон при TRADING_CYCLE_ENABLED=true)
# TRADING_CYCLE_TICKERS=
# DASHBOARD_WATCHLIST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT,META,AMZN

# ============================================
# Web Interface Configuration
# ============================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
# /parameters: ключи = незакомментированные строки в этом файле (кроме секретов в blocklist в config_loader).
# Плюс GAME_5M_TAKE_PROFIT_PCT_<T> / GAME_5M_MAX_POSITION_DAYS_<T> по TICKERS_FAST.
# Перезапуск после правок в вебе; пусто — `docker compose restart lse` (нужен docker в PATH; иначе код 127).
# Пример с полным путём: RESTART_CMD=/usr/bin/docker compose -f /path/to/lse/docker-compose.yml restart lse
RESTART_CMD=

# ============================================
# Analyzer autotune (эволюционный тюнинг)
# ============================================
# Идея: 1 изменение → подождать окно → сравнить → следующее.
# По умолчанию APPLY выключен: скрипт только выбирает кандидат и пишет local/autotune_state.json.
# Запуск: python3 scripts/analyzer_autotune.py --days 5 --url http://127.0.0.1:8080/api/analyzer
ANALYZER_AUTOTUNE_APPLY=0
# Сколько новых сделок нужно набрать после применения, чтобы пометить pending как ready_for_review.
ANALYZER_AUTOTUNE_MIN_TRADES=8
# Запретить ключи (через запятую); по умолчанию не трогаем cron.
ANALYZER_AUTOTUNE_DENY_KEYS=GAME_5M_SIGNAL_CRON_MINUTES
# Предпочтения выбора (префиксы через запятую): сначала per-ticker cap, затем factor.
ANALYZER_AUTOTUNE_PREFER_PREFIXES=GAME_5M_TAKE_PROFIT_PCT_,GAME_5M_TAKE_MOMENTUM_FACTOR
# Где хранить состояние (если не задано — local/autotune_state.json).
# ANALYZER_AUTOTUNE_STATE_PATH=/var/lib/lse/autotune_state.json

# ============================================
# News: источники, ключи, тюнинг (knowledge_base)
# ============================================
# Карта (имена совпадают с NYSE там, где указано — один ключ можно держать в обоих config.env):
#   Секреты:     NEWSAPI_KEY | ALPHAVANTAGE_KEY | MARKETAUX_API_KEY  (опционально: NYSE_CONFIG_PATH → подмешать nyse/config.env)
#   Макро/агрегаторы: NewsAPI (+NEWSAPI_*), Alpha Vantage (+ALPHAVANTAGE_*, EARNINGS_*)
#   Тикерные NYSE-style: Yahoo (без ключа) + Marketaux — TICKER_NEWS_* и MARKETAUX_API_KEY
#   Investing.com: INVESTING_NEWS_* (HTML лента); календарь — только JSON API (как nyse); INVESTING_CALENDAR_USE_HTML=true — legacy HTML
#   RSS ЦБ: без ключей (URL в коде services/rss_news_fetcher.py)
# Лимиты API: docs/NEWS_LIMITS.md. Сбор: scripts/fetch_news_cron.py (--mode all|core|core-fast|newsapi|investing|tickers).
#
# База знаний: сохранять только тикеры из TICKERS_* + MACRO (true) или всё входящее от Alpha Vantage / LLM-новостей (false — по умолчанию).
# KB_INGEST_TRACKED_TICKERS_ONLY=false
#
# --- Объём новостей для LLM / решений (см. docs/NEWS_LIMITS.md) ---
# Лимиты (типично): NewsAPI developer ~100 HTTP-запросов/сутки — каждая СТРАНИЦА = 1 запрос; макро + equity = 2+ запроса за один запуск fetch_news_cron --mode newsapi.
# Alpha Vantage free ~25 запросов/сутки — не включайте лишние economic/technical без нужды.
# Окно для аналитика/бота (сколько часов новостей из KB смотреть): по умолчанию 336 ч = 14 дней.
# KB_NEWS_LOOKBACK_HOURS=336

# --- NewsAPI.org (имя ключа как в NYSE: NEWSAPI_KEY) ---
# NewsAPI.org - агрегатор новостей (бесплатный tier: ~100 запросов/день — каждая страница = отдельный запрос)
# NEWSAPI_KEY=your_newsapi_key_here
# Один объединённый макро-запрос вместо 5 отдельных (по умолчанию true). false — старый режим (сжигает лимит).
# NEWSAPI_MACRO_SINGLE_QUERY=true
# Свой запрос вместо встроенного DEFAULT_MACRO_QUERY (длинная строка OR …); можно добавить геополитику: … OR (Ukraine OR Taiwan OR sanctions OR Gaza)
# NEWSAPI_MACRO_QUERY=
# Сколько страниц по ~100 статей за ОДИН макро-запуск (1 = экономия). Макс. 5. Для большего потока: 2–3.
# NEWSAPI_MAX_PAGES=2
# Глубина «from» для /everything (дней назад). Код: до 30. Для решений за 2 недели: 14.
# NEWSAPI_DAYS_BACK=14
# Второй запрос по тикерам портфеля (OR по символам из EARNINGS_TRACK_TICKERS или TICKERS_FAST). +N страниц см. NEWSAPI_EQUITY_MAX_PAGES.
# NEWSAPI_FETCH_EQUITY=true
# NEWSAPI_EQUITY_MAX_PAGES=2
# Явный список тикеров для equity-запроса (пусто = EARNINGS_TRACK_TICKERS или TICKERS_FAST)
# NEWSAPI_EQUITY_TICKERS=SNDK,MU,MSFT,LITE,ALAB,TER
# После 429 не вызывать NewsAPI N часов (файл cooldown в logs). Сброс: удалить файл.
# NEWSAPI_COOLDOWN_AFTER_429_HOURS=12
# После 426 Upgrade Required (план/эндпоинт) — пауза, чтобы не спамить логи каждый cron.
# NEWSAPI_COOLDOWN_AFTER_426_HOURS=24
# NEWSAPI_COOLDOWN_FILE=/app/logs/.newsapi_cooldown_until

# --- Alpha Vantage (ключ как в NYSE: ALPHAVANTAGE_KEY; дубликат имени: ALPHAVANTAGE_API_KEY) ---
# Alpha Vantage - Earnings Calendar и News Sentiment
# ALPHAVANTAGE_KEY=your_alphavantage_key_here
# Бесплатный план: 25 запросов/день. Экономические и технические индикаторы съедают лимит — оставьте выключенными:
# ALPHAVANTAGE_FETCH_ECONOMIC=false
# ALPHAVANTAGE_FETCH_TECHNICAL=false
# (по умолчанию оба false; тогда идут только Earnings + News.)
# Не сохранять Earnings Calendar в KB (записи «Earnings report for X» — мусор). Очистка: scripts/cleanup_calendar_noise.py
# EARNINGS_CALENDAR_SAVE=false
# Тикеры для Alpha Vantage Earnings (если EARNINGS_CALENDAR_SAVE=true): EARNINGS_TRACK_TICKERS=MSFT,SNDK,MU,LITE,ALAB,TER
# Таймауты/повторы (опционально): ALPHAVANTAGE_TIMEOUT=90 ALPHAVANTAGE_MAX_RETRIES=3 ALPHAVANTAGE_RETRY_DELAY=10 ALPHAVANTAGE_MIN_DELAY_SEC=1

# --- Marketaux (имя ключа как в NYSE: MARKETAUX_API_KEY; дополняет Yahoo, не заменяет) ---
# Используется в fetch_news_cron --mode tickers | core | all (слой TickerNews).
# MARKETAUX_API_KEY=your_marketaux_api_key_here
# Не дублировать ключ в двух файлах: подмешать nyse/config.env (только пустые ключи LSE).
# NYSE_CONFIG_PATH=/home/you/projects/nyse/config.env

# --- Ticker news (NYSE-style): Yahoo (yfinance) + Marketaux merge ---
# Список тикеров для тикерных новостей. Пусто = TICKERS_FAST.
# TICKER_NEWS_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT
# Окно новостей (часы), по умолчанию 48.
# TICKER_NEWS_LOOKBACK_HOURS=48
# Yahoo: сколько новостей просить на тикер, по умолчанию 40.
# TICKER_NEWS_MAX_PER_TICKER=40
# Метка exchange для knowledge_base (по умолчанию NYSE).
# TICKER_NEWS_EXCHANGE=NYSE

# --------------------------------------------
# Investing.com News (лента stock-market-news)
# --------------------------------------------
# Сколько заголовков просматривать с ленты за запуск (фильтр по ключевым словам; не все попадут в KB). 10–80.
# INVESTING_NEWS_MAX_ARTICLES=50
# Тикеры — из TICKERS_FAST + MEDIUM + LONG (в т.ч. индикаторы ^VIX, товары BZ=F, GC=F). Ключевые слова — встроенные
# (SNDK, AMD, CL=F, BZ=F, GC=F, ^VIX и др.). Опционально дополнение (добавляет к встроенным, не заменяет):
# Формат: ТИКЕР:слово1,слово2;ДРУГОЙ:слово3 (запятая — разделитель слов; пробелы в слове допустимы, например "Brent Oil")
# INVESTING_NEWS_TICKER_KEYWORDS=SNDK:Citron,short;AMD:Advanced Micro Devices;BZ=F:Brent Oil;Brent;^VIX:VIX,volatility
# При 403 Forbidden задайте HTTP(S)-прокси (браузерный или резидентный).
# Только http:// или https:// — socks5:// при загрузке config в окружение ломает загрузку моделей (vector_kb).
# Если прокси нет — закомментируйте или удалите строку.
# INVESTING_NEWS_PROXY=http://user:pass@host:port
# Таймаут чтения HTML ленты (сек), при таймауте — один повтор. По умолчанию 55.
# INVESTING_NEWS_TIMEOUT=55
# true — отбрасывать новость, если заголовок сопоставился с тикером не из списка KB (старое поведение; много «тихих» потерь).
# false — сохранять такие строки как MACRO (по умолчанию).
# INVESTING_NEWS_STRICT_TRACKED_ONLY=false

# --- KB /news: nyse-стиль REG-кластер (TF-IDF) для draft_impulse / гейта (имена ключей как в репозитории nyse) ---
# NYSE_REGIME_CLUSTER=1
# NYSE_REGIME_CLUSTER_THRESHOLD=0.88
# NYSE_REGIME_CLUSTER_EMBED=tfidf
# (openai-эмбеддинги в LSE не подключены — при openai принудительно TF-IDF)

# --- Investing.com Economic Calendar (macro KB), как nyse — только API ---
# JSON API без ключа: services/investing_calendar_api.py. Авто-fallback на HTML нет.
# true — только legacy-скрапинг HTML по регионам (если API недоступен — не включайте без нужды).
# INVESTING_CALENDAR_USE_HTML=false
# Прокси из окружения для запросов календаря: INVESTING_CALENDAR_USE_SYSTEM_PROXY=true (PySocks для socks).

# Примечание: LLM-новости (USE_LLM_NEWS и т.п.) в fetch_news_cron не вызываются; cron — RSS, NewsAPI, Alpha Vantage, TickerNews (Yahoo+Marketaux), Investing.

# ============================================
# Telegram Bot Configuration
# ============================================
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_SIGNAL_CHAT_ID=your_signal_chat_id
# TELEGRAM_ALLOWED_USERS=user_id1,user_id2
# TELEGRAM_WEBHOOK_URL=https://your-service.run.app/webhook
# Прокси для доступа к api.telegram.org (если заблокирован): http://host:port или https://...
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# Рассылка сигналов (send_sndk_signal_cron, premarket): чаты через запятую или один TELEGRAM_SIGNAL_CHAT_ID
# TELEGRAM_SIGNAL_CHAT_IDS=chat_id1,chat_id2
# TELEGRAM_SIGNAL_CHAT_ID=один_чат
# Упоминания в сообщениях (например @username): TELEGRAM_SIGNAL_MENTIONS=@user1 @user2
# Чат для дашборда (send_dashboard_cron): TELEGRAM_DASHBOARD_CHAT_ID=chat_id
# Лимиты отчётов /closed и /closed_impulse (HTML-файл в чат): сколько последних закрытых показывать по умолчанию и верхняя граница по числу N в команде
# TELEGRAM_CLOSED_REPORT_DEFAULT=25
# TELEGRAM_CLOSED_REPORT_MAX=200
# Веб /reports/closed и Excel: верхний лимит строк (не ниже TELEGRAM_CLOSED_REPORT_MAX). Пример: 500
# WEB_CLOSED_REPORT_MAX=500

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_DIR=logs

# Полный разбор опций и рекомендации: docs/CONFIG_OPTIONS_ANALYSIS.md

