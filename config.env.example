# ============================================
# Конфигурация LSE Trading System (шаблон)
# ============================================
# Скопируйте этот файл в config.env и подставьте свои ключи (LLM, новости, Telegram и т.д.).
# Отдельная настройка не нужна: приложение читает config.env при старте; отсутствующие ключи — соответствующий источник отключён или используется дефолт.

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/lse_trading

# ============================================
# OpenAI/ProxyAPI Configuration
# ============================================
OPENAI_API_KEY=your_proxyapi_key_here
# Прокси OpenAI: https://api.proxyapi.ru/openai/v1
# OpenRouter (через proxyapi): https://api.proxyapi.ru/openrouter/v1 — тогда OPENAI_MODEL = id из OpenRouter (например anthropic/claude-sonnet-4.6)
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60
# Сравнение нескольких моделей: через запятую "model" или "provider|model" (openai, anthropic, google)
# Пример: gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# LLM_COMPARE_MODELS=gpt-4o,openai|gpt-5.2,anthropic|claude-opus-4-6,google|gemini-3.1-pro-preview
# Подбор модели: docs/LLM_MODEL_SELECTION.md

# ============================================
# Embedding Configuration (для векторной БЗ — Vector KB)
# ============================================
# Локальная модель (sentence-transformers / Hugging Face). Используется, если не включены облачные эмбеддинги.
# Примеры: intfloat/multilingual-e5-base (мультиязычный, 768 dim), sentence-transformers/all-mpnet-base-v2
HF_MODEL_NAME=intfloat/multilingual-e5-base

# Облачные эмбеддинги (если локальная модель даёт Bus error / core dumped):
# USE_OPENAI_EMBEDDINGS=true
# (тот же OPENAI_API_KEY и OPENAI_BASE_URL что для GPT-4o; модель text-embedding-3-small, 768 dim)
# Альтернатива — Gemini: USE_GEMINI_EMBEDDINGS=true, GEMINI_API_KEY=...

# ============================================
# Sentiment Analysis Configuration
# ============================================
# При добавлении новостей (CLI, CSV, веб): считать sentiment через LLM сразу
SENTIMENT_AUTO_CALCULATE=true
# Модель для LLM задаётся в OPENAI_MODEL выше; SENTIMENT_LLM_MODEL не используется в коде
# USE_LLM — применение LLM: при false не используем LLM; иначе — да.
# Управляет: аналитик в Telegram-боте (/signal, /recommend, /ask, /prompt_entry), trading_cycle_cron (ExecutionAgent),
# крон add_sentiment_to_news_cron (backfill sentiment по новостям). В дальнейшем можно хранить в БД (strategy_parameters GLOBAL).
# USE_LLM=false
USE_LLM=true

# ============================================
# Trading Configuration
# ============================================
# Начальный капитал и кэш — в local/risk_limits.json (risk_capacity.total_capital_usd).
# Чтобы увеличить кэш: отредактировать total_capital_usd и в БД: UPDATE portfolio_state SET quantity = <сумма> WHERE ticker = 'CASH';
COMMISSION_RATE=0
# Порог стоп-лосса портфеля: при падении цены ниже этого уровня (лог-доходность) позиция закрывается. 0.95 ≈ −5%
STOP_LOSS_LEVEL=0.95
# Стоп-лосс портфеля: true = проверять по STOP_LOSS_LEVEL; false = отключён (в логах — предупреждение, закрывается только по тейку).
# Можно переопределить в БД: strategy_parameters (GLOBAL) — PORTFOLIO_STOP_LOSS_ENABLED, STOP_LOSS_LEVEL.
# PORTFOLIO_STOP_LOSS_ENABLED=false
# Песочница: проскальзывание при продаже (%). Реальная цена исполнения может быть хуже последней котировки (цена просела). 0 = отключено, 0.3 = консервативно.
# SANDBOX_SLIPPAGE_SELL_PCT=0.3

# ============================================
# Игры: быстрая (5m) и портфельная
# ============================================
# Фокус: быстрая игра 5m (daily на волатильных стоках). Портфельная игра пока не актуальна — все силы на 5m.
# Корреляция: учитываем «все со всеми» — торгуемые 5m + контекст (фон MSFT/META/AMZN, индикаторы NVDA, SMH, QQQ, VIX, нефть, forex).
# Cron: GAME 5m — send_sndk_signal_cron.py. Портфель — trading_cycle_cron.py (опционально).
# См. docs/TICKER_GROUPS.md

# ---- Быстрая игра (5m): прогнозы для вступления — приоритет; трейдер играет сам, информация по возможности раньше ----
# Целевые стоки для daily (Alex: SNDK, NBIS — лидеры; ASML, MU — AI; LITE, CIEN — волатильные)
TICKERS_FAST=SNDK,NBIS,ASML,MU,LITE,CIEN
# Тикеры, по которым крон запускает игру 5m (вход/выход). Пусто = все из TICKERS_FAST.
# GAME_5M_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN
# Контекст для корреляции «все со всеми»: фон + индикаторы волатильности (^VIX) + геополитика (нефть CL=F, золото GC=F) + forex. Не торгуем ими в 5m.
GAME_5M_CORRELATION_CONTEXT=MSFT,META,AMZN,NVDA,SMH,QQQ,TLT,^VIX,CL=F,GC=F,GBPUSD=X
# Cooldown между рассылками сигнала на вход по одному тикеру (минуты)
GAME_5M_COOLDOWN_MINUTES=120
# Параметры стратегии 5m (видны в game5m_status, /game5m, API). Анализ убытков: docs/GAME_5M_CLOSED_ANALYSIS.md
# Стоп 5m: false = закрытие только по тейку / TIME_EXIT / SELL (Alex: без стопа по лоссу)
# GAME_5M_STOP_LOSS_ENABLED=false
GAME_5M_STOP_TO_TAKE_RATIO=0.5
GAME_5M_STOP_LOSS_PCT=1.5
GAME_5M_MAX_POSITION_DAYS=1
GAME_5M_STOP_LOSS_MIN_PCT=0.5
# Потолок тейка (%). Тейк по импульсу: если импульс_2ч >= GAME_5M_TAKE_PROFIT_MIN_PCT — тейк = min(импульс_2ч × factor, потолок); иначе тейк = потолок. Поэтому при импульсе 6% тейк срабатывает на 6%, а не на 7%.
GAME_5M_TAKE_PROFIT_PCT=7
# Импульсы менее этого % не рассматриваем — тейк = потолок (GAME_5M_TAKE_PROFIT_PCT). Иначе тейк от импульса 2ч (Alex: от 4%).
GAME_5M_TAKE_PROFIT_MIN_PCT=4.0
# Тейк от импульса 2ч: factor (1.0 = полный импульс; 0.8 = консервативнее, фиксируем раньше).
# GAME_5M_TAKE_MOMENTUM_FACTOR=0.8
# Потолок тейка по тикеру (опционально): SNDK=8 → для SNDK макс. тейк 8%, для остальных — GAME_5M_TAKE_PROFIT_PCT.
# GAME_5M_TAKE_PROFIT_PCT_SNDK=8
# GAME_5M_TAKE_PROFIT_PCT_MU=5

# ---- Портфельная игра (пока не в фокусе: Neutral, Mean Reversion, Momentum и т.д.) ----
# Тейк-профит по умолчанию (%) для позиций без тейка при входе. 0 = не закрывать по тейку.
# PORTFOLIO_TAKE_PROFIT_PCT=3.0

# Премаркет-крон (scripts/premarket_cron.py): при true отправлять алерт в Telegram (тикеры, гэп %, мин до открытия)
# PREMARKET_ALERT_TELEGRAM=false
# Прогноз на вступление (5m) в премаркете: при true в алерт добавляется блок по тикерам игры 5m (решение до открытия) — информация раньше
# PREMARKET_ENTRY_PREVIEW_5M=true
# Геополитический/премаркет-стресс: тикеры-индикаторы (Forex, нефть). При гэпе вниз ниже порога — алерт «закрыть GAME_5m и прочие до открытия» (в пятницу — до выходных).
# PREMARKET_STRESS_TICKERS=GBPUSD=X,EURUSD=X,CL=F
# PREMARKET_STRESS_GAP_PCT=-1.5
# Алерт стресс только в пятницу (true) или в любой день при стрессе (false)
# PREMARKET_STRESS_ALERT_FRIDAY_ONLY=true
# Watchdog логов cron (scripts/cron_watchdog.py): при true при находках ошибок в логах — уведомление в Telegram
# CRON_WATCHDOG_TELEGRAM=false

# ---- Портфельная игра (дневные стратегии; пока не в фокусе — все силы на 5m) ----
# Тикеры для KB и сбора новостей (Investing.com, fetch_news_cron): FAST + MEDIUM + LONG.
# Важно: нефть (CL=F), золото (GC=F), ^VIX в LONG — по ним собираются новости (BUILTIN_KEYWORDS в коде). Для корреляции 5m — GAME_5M_CORRELATION_CONTEXT.
TICKERS_MEDIUM=ALAB,MU,TER,AMD
# Долгие: фон (MSFT, META, AMZN), forex, индикаторы волатильности (^VIX), геополитика (нефть CL=F, золото GC=F)
TICKERS_LONG=MSFT,META,AMZN,GBPUSD=X,GC=F,^VIX,CL=F
# OIL_TICKER=CL=F
# Явный список для trading_cycle_cron (пусто или не задан = MEDIUM+LONG; можно отключить крон)
# TRADING_CYCLE_TICKERS=
# DASHBOARD_WATCHLIST=SNDK,NBIS,ASML,MU,LITE,CIEN,MSFT,META,AMZN

# ============================================
# Web Interface Configuration
# ============================================
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ============================================
# News Sources API Keys
# ============================================
# NewsAPI.org - агрегатор новостей (бесплатный tier: 100 запросов/день)
# NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage - Earnings Calendar и News Sentiment
# ALPHAVANTAGE_KEY=your_alphavantage_key_here
# Бесплатный план: 25 запросов/день. Экономические и технические индикаторы съедают лимит — оставьте выключенными:
# ALPHAVANTAGE_FETCH_ECONOMIC=false
# ALPHAVANTAGE_FETCH_TECHNICAL=false
# (по умолчанию оба false; тогда идут только Earnings + News.)
# Не сохранять Earnings Calendar в KB (записи «Earnings report for X» — мусор). Очистка: scripts/cleanup_calendar_noise.py
# EARNINGS_CALENDAR_SAVE=false
# Тикеры для Alpha Vantage Earnings (если EARNINGS_CALENDAR_SAVE=true): EARNINGS_TRACK_TICKERS=MSFT,SNDK,MU,LITE,ALAB,TER
# Таймауты/повторы (опционально): ALPHAVANTAGE_TIMEOUT=90 ALPHAVANTAGE_MAX_RETRIES=3 ALPHAVANTAGE_RETRY_DELAY=10 ALPHAVANTAGE_MIN_DELAY_SEC=1

# --------------------------------------------
# Investing.com News (лента stock-market-news)
# --------------------------------------------
# Тикеры — из TICKERS_FAST + MEDIUM + LONG (в т.ч. индикаторы ^VIX, товары BZ=F, GC=F). Ключевые слова — встроенные
# (SNDK, AMD, CL=F, BZ=F, GC=F, ^VIX и др.). Опционально дополнение (добавляет к встроенным, не заменяет):
# Формат: ТИКЕР:слово1,слово2;ДРУГОЙ:слово3 (запятая — разделитель слов; пробелы в слове допустимы, например "Brent Oil")
# INVESTING_NEWS_TICKER_KEYWORDS=SNDK:Citron,short;AMD:Advanced Micro Devices;BZ=F:Brent Oil;Brent;^VIX:VIX,volatility
# При 403 Forbidden задайте HTTP(S)-прокси (браузерный или резидентный).
# Только http:// или https:// — socks5:// при загрузке config в окружение ломает загрузку моделей (vector_kb).
# Если прокси нет — закомментируйте или удалите строку.
# INVESTING_NEWS_PROXY=http://user:pass@host:port

# --------------------------------------------
# LLM как источник новостей (перед решением 5m и в cron)
# --------------------------------------------
# USE_LLM_NEWS=true
# LLM_NEWS_TICKERS=SNDK,AMD,MSFT
# Не чаще одной LLM-новости по тикеру за N часов; плюс дедупликация по содержанию (по умолч. 168 = 7 дней)
# LLM_NEWS_COOLDOWN_HOURS=168

# ============================================
# Telegram Bot Configuration
# ============================================
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_ALLOWED_USERS=user_id1,user_id2
# TELEGRAM_WEBHOOK_URL=https://your-service.run.app/webhook
# Прокси для доступа к api.telegram.org (если заблокирован): http://host:port или https://...
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# Рассылка сигналов (send_sndk_signal_cron, premarket): чаты через запятую или один TELEGRAM_SIGNAL_CHAT_ID
# TELEGRAM_SIGNAL_CHAT_IDS=chat_id1,chat_id2
# TELEGRAM_SIGNAL_CHAT_ID=один_чат
# Упоминания в сообщениях (например @username): TELEGRAM_SIGNAL_MENTIONS=@user1 @user2
# Чат для дашборда (send_dashboard_cron): TELEGRAM_DASHBOARD_CHAT_ID=chat_id

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_DIR=logs

# Полный разбор опций и рекомендации: docs/CONFIG_OPTIONS_ANALYSIS.md

