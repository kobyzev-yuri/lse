# =============================================================================
# config.env.lse — фрагмент для вручную переноса в боевой config.env на сервере.
# Секреты (DB, Telegram, ключи) сюда не копируйте — только блок GAME_5M / висяки.
# После слияния: docker compose restart lse
# =============================================================================

# --- Офлайн JSON (open_agg): remediation_take_cap по тикерам; файл должен существовать в контейнере ---
# Скопируйте свежий hanger_tune_open_agg.json в ./logs на хосте (том → /app/logs).
GAME_5M_HANGER_TUNE_JSON=/app/logs/hanger_tune_open_agg.json
GAME_5M_HANGER_TUNE_APPLY_TAKE=true

# --- Live dual: если live_aggregate_hanger_diagnosis подтвердил «висяк» — сужение JSON + TAKE_PROFIT_SUSPEND при ценовом тейке ---
GAME_5M_HANGER_DUAL_MODE=true
GAME_5M_HANGER_LIVE_CALENDAR_DAYS=6
GAME_5M_HANGER_LIVE_SAG_EPSILON_LOG=0
GAME_5M_HANGER_LIVE_SKIP_SAG=false
# Горизонт баров для live-диагностики (как в бэктесте)
GAME_5M_BAR_HORIZON_DAYS=10

# --- Временно 1–2 дня: per-ticker cap ниже на ~1 п.п. (итоговый тейк = min(env, JSON proposed)). Потом вернуть или поднять. ---
GAME_5M_TAKE_PROFIT_PCT_ASML=4
GAME_5M_TAKE_PROFIT_PCT_SNDK=5
GAME_5M_TAKE_PROFIT_PCT_NBIS=5.5

# =============================================================================
# Логи тактики висяков (каждые 5m при открытой GAME_5M позиции):
#   grep HANGER_TACTIC logs/cron_sndk_signal.log
#   grep -E 'HANGER_TACTIC|AFTER_HOURS HANGER_TACTIC' logs/cron_sndk_signal.log
#
# Сводка по строкам лога (без LLM):
#   python scripts/analyze_hanger_tactic_log.py logs/cron_sndk_signal.log
#
# Комментарии анализатора по закрытым сделкам в БД (не по сырому логу; опционально --llm):
#   python scripts/analyze_trades_focused.py --days 5 --tickers ASML,SNDK,NBIS,MU,LITE,CIEN --llm
#
# Полный недельный отчёт + блок висяков офлайн:
#   python scripts/analyze_trade_effectiveness_weekly.py --days 7 --game5m-param-backtest --json-out logs/analyzer_week.json
# =============================================================================
