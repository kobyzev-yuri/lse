# ============================================
# LSE Trading System configuration (server template)
# ============================================
# Этот файл предназначен для сервера/cron и заменяет “фрагмент”.
# Он содержит ВСЕ ключи, которые есть в текущем `config.env` в репозитории,
# но чувствительные значения заменены на плейсхолдеры.
#
# Секреты храните в `config.secrets.env` / `config.security.env` или в переменных окружения.
# Приоритет: env процесса > config.env > config.secrets.env > config.security.env (см. config_loader.py).
#
# После правок: docker compose restart lse

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://USER:PASS@HOST:5432/lse_trading

# ============================================
# OpenAI/ProxyAPI Configuration
# ============================================
OPENAI_API_KEY=__PUT_YOUR_KEY_HERE__
#OPENAI_GPT_KEY=__OPTIONAL_FALLBACK_KEY__
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60
# LLM_COMPARE_MODELS=

# ============================================
# Embedding Configuration (vector KB — Vector KB)
# ============================================
HF_MODEL_NAME=intfloat/multilingual-e5-base
# USE_OPENAI_EMBEDDINGS=true
# USE_GEMINI_EMBEDDINGS=true
# GEMINI_API_KEY=__PUT_YOUR_KEY_HERE__

# ============================================
# Sentiment Analysis Configuration
# ============================================
SENTIMENT_AUTO_CALCULATE=true
USE_LLM=true

# ============================================
# Trading Configuration
# ============================================
COMMISSION_RATE=0
STOP_LOSS_LEVEL=0.95
# PORTFOLIO_STOP_LOSS_ENABLED=false
# SANDBOX_SLIPPAGE_SELL_PCT=0.3

# ============================================
# Games: fast (5m) and portfolio
# ============================================
TICKERS_FAST=SNDK,NBIS,ASML,MU,LITE,CIEN
# GAME_5M_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN
GAME_5M_CORRELATION_CONTEXT=MSFT,META,AMZN,NVDA,SMH,QQQ,TLT,^VIX,CL=F,GC=F,GBPUSD=X
GAME_5M_SIGNAL_CRON_MINUTES=1
GAME_5M_COOLDOWN_MINUTES=120
GAME_5M_STOP_LOSS_ENABLED=false
GAME_5M_STOP_TO_TAKE_RATIO=0.5
GAME_5M_STOP_LOSS_PCT=1.5
GAME_5M_STOP_LOSS_MIN_PCT=0.5

GAME_5M_MAX_ATR_5M_PCT=1.13
#GAME_5M_MIN_VOLUME_VS_AVG_PCT=50

GAME_5M_TAKE_PROFIT_PCT=5.8
GAME_5M_TAKE_PROFIT_PCT_SNDK=6
GAME_5M_TAKE_PROFIT_PCT_NBIS=6.5
GAME_5M_TAKE_PROFIT_PCT_ASML=5
GAME_5M_TAKE_PROFIT_PCT_MU=0.5
GAME_5M_TAKE_PROFIT_PCT_LITE=0.5
GAME_5M_TAKE_PROFIT_PCT_CIEN=5.5

GAME_5M_MAX_POSITION_DAYS=1
GAME_5M_MAX_POSITION_DAYS_SNDK=3
GAME_5M_MAX_POSITION_DAYS_NBIS=5
GAME_5M_MAX_POSITION_DAYS_ASML=1
GAME_5M_MAX_POSITION_DAYS_MU=4
GAME_5M_MAX_POSITION_DAYS_LITE=4
GAME_5M_MAX_POSITION_DAYS_CIEN=3

GAME_5M_SESSION_END_EXIT_MINUTES=30
GAME_5M_SESSION_END_MIN_PROFIT_PCT=0.3
GAME_5M_TAKE_PROFIT_MIN_PCT=3.0
# GAME_5M_TAKE_MOMENTUM_FACTOR=0.8

TRADING_CYCLE_ENABLED=false # portfolio game paused when false
# PORTFOLIO_TAKE_PROFIT_PCT=3.0

PREMARKET_ALERT_TELEGRAM=false
PREMARKET_ENTRY_PREVIEW_5M=true
PREMARKET_STRESS_TICKERS=GBPUSD=X,EURUSD=X,CL=F
PREMARKET_STRESS_GAP_PCT=-1.5
PREMARKET_STRESS_ALERT_FRIDAY_ONLY=true
# CRON_WATCHDOG_TELEGRAM=false

TICKERS_MEDIUM=ALAB,MU,TER,AMD
TICKERS_LONG=MSFT,META,AMZN,GBPUSD=X,GC=F,^VIX,CL=F,BZ=F,ORCL
OIL_TICKER=CL=F
# TRADING_CYCLE_TICKERS=
# DASHBOARD_WATCHLIST=

# ============================================
# Web Interface Configuration
# ============================================
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ============================================
# News Sources API Keys
# ============================================
KB_INGEST_TRACKED_TICKERS_ONLY=false
KB_NEWS_LOOKBACK_HOURS=336

NEWSAPI_KEY=__PUT_YOUR_KEY_HERE__
NEWSAPI_MACRO_SINGLE_QUERY=true
NEWSAPI_MAX_PAGES=2
NEWSAPI_DAYS_BACK=14
NEWSAPI_FETCH_EQUITY=true
NEWSAPI_EQUITY_MAX_PAGES=2
NEWSAPI_EQUITY_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN,ALAB,TER,AMD,MSFT,META,AMZN,ORCL
NEWSAPI_COOLDOWN_AFTER_429_HOURS=12
# NEWSAPI_COOLDOWN_FILE=/app/logs/.newsapi_cooldown_until

EARNINGS_TRACK_TICKERS=SNDK,NBIS,ASML,MU,LITE,CIEN,ALAB,TER,AMD,MSFT,META,AMZN,ORCL
ALPHAVANTAGE_KEY=__PUT_YOUR_KEY_HERE__
ALPHAVANTAGE_FETCH_ECONOMIC=false
ALPHAVANTAGE_FETCH_TECHNICAL=false

INVESTING_NEWS_MAX_ARTICLES=50
INVESTING_CALENDAR_USE_HTML=false
INVESTING_NEWS_TICKER_KEYWORDS=SNDK:Citron,short;AMD:Advanced Micro Devices;BZ=F:Brent Oil;Brent;^VIX:VIX,volatility;ORCL:Oracle
# INVESTING_NEWS_PROXY=http://user:pass@host:port

# ============================================
# LLM as news source (before 5m decision and in cron)
# ============================================
USE_LLM_NEWS=false
SENTIMENT_METHOD=transformers
SENTIMENT_MODEL=ProsusAI/finbert
GAME_5M_USE_LLM_NEWS=false
GAME_5M_EXIT_ONLY_TAKE=true
PORTFOLIO_EXIT_ONLY_TAKE=true
GAME_5M_CATBOOST_ENABLED=false
LLM_NEWS_TICKERS=SNDK,AMD,MSFT,ORCL,META,AMZN
LLM_NEWS_COOLDOWN_HOURS=168

# ============================================
# Telegram Bot Configuration
# ============================================
TELEGRAM_BOT_TOKEN=__PUT_YOUR_TOKEN_HERE__
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_PROXY_URL=
TELEGRAM_SIGNAL_CHAT_IDS=__PUT_CHAT_ID_OR_IDS_HERE__
# TELEGRAM_SIGNAL_CHAT_ID=
# TELEGRAM_SIGNAL_MENTIONS=
# TELEGRAM_DASHBOARD_CHAT_ID=

GAME_5M_ENTRY_QUALITY_GUARD_ENABLED=true
GAME_5M_ENTRY_QUALITY_MIN_RR=1.2
GAME_5M_ENTRY_QUALITY_MIN_EV_PCT=0.0

GAME_5M_MAX_POSITION_MINUTES_SNDK=1170
GAME_5M_MAX_POSITION_MINUTES_NBIS=1950
GAME_5M_MAX_POSITION_MINUTES_ASML=390
GAME_5M_MAX_POSITION_MINUTES_MU=1560
GAME_5M_MAX_POSITION_MINUTES_LITE=1560
GAME_5M_MAX_POSITION_MINUTES_CIEN=1170

GAME_5M_EARLY_DERISK_ENABLED=false
GAME_5M_EARLY_DERISK_MIN_AGE_MINUTES=240
GAME_5M_EARLY_DERISK_MAX_LOSS_PCT=-2.2
GAME_5M_EARLY_DERISK_MOMENTUM_BELOW=-0.2

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_DIR=logs

GAME_5M_RTH_MOMENTUM_BUY_MIN=0.6
GAME_5M_RSI_BUY_MAX=35
PLATFORM_GAME_API_ENABLED=true
PLATFORM_GAME_API_URL=http://platform-game:8080/game
PLATFORM_GAME_API_TIMEOUT_SEC=15
GAME_5M_TAKE_MOMENTUM_FACTOR=1.1
GAME_5M_RSI_FOR_MOMENTUM_BUY_MAX=64
GAME_5M_RSI_STRONG_BUY_MAX=34
GAME_5M_ALLOW_PYRAMID_BUY=false
GAME_5M_SOFT_TAKE_NEAR_HIGH_ENABLED=true
# GAME_5M_SOFT_TAKE_NEAR_HIGH_MIN_PCT=2.0
# GAME_5M_SOFT_TAKE_MAX_PULLBACK_FROM_HIGH_PCT=0.35

# ============================================
# Hanger / take-cap overlays (GAME_5M)
# ============================================
# Офлайн JSON (open_agg): remediation_take_cap по тикерам; файл должен существовать в контейнере.
# Скопируйте свежий hanger_tune_open_agg.json в ./logs на хосте (том → /app/logs).
GAME_5M_HANGER_TUNE_JSON=/app/logs/hanger_tune_open_agg.json
GAME_5M_HANGER_TUNE_APPLY_TAKE=true

# Live dual: если live_aggregate_hanger_diagnosis подтвердил «висяк» — сужение JSON + TAKE_PROFIT_SUSPEND при ценовом тейке.
GAME_5M_HANGER_DUAL_MODE=true
GAME_5M_HANGER_LIVE_CALENDAR_DAYS=6
GAME_5M_HANGER_LIVE_SAG_EPSILON_LOG=0
GAME_5M_HANGER_LIVE_SKIP_SAG=false
# Горизонт баров для live-диагностики (как в бэктесте)
GAME_5M_BAR_HORIZON_DAYS=10

# Временно 1–2 дня: per-ticker cap ниже на ~1 п.п. (итоговый тейк = min(env, JSON proposed)). Потом вернуть или поднять.
GAME_5M_TAKE_PROFIT_PCT_ASML=4
GAME_5M_TAKE_PROFIT_PCT_SNDK=5
GAME_5M_TAKE_PROFIT_PCT_NBIS=5.5

# =============================================================================
# Логи тактики висяков (каждые 5m при открытой GAME_5M позиции):
#   grep HANGER_TACTIC logs/cron_sndk_signal.log
#   grep -E 'HANGER_TACTIC|AFTER_HOURS HANGER_TACTIC' logs/cron_sndk_signal.log
#
# Сводка по строкам лога (без LLM):
#   python scripts/analyze_hanger_tactic_log.py logs/cron_sndk_signal.log
#
# Комментарии анализатора по закрытым сделкам в БД (не по сырому логу; опционально --llm):
#   python scripts/analyze_trades_focused.py --days 5 --tickers ASML,SNDK,NBIS,MU,LITE,CIEN --llm
#
# Полный недельный отчёт + блок висяков офлайн:
#   python scripts/analyze_trade_effectiveness_weekly.py --days 7 --game5m-param-backtest --json-out logs/analyzer_week.json
# =============================================================================
