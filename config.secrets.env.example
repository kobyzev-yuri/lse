# ============================================
# Секреты LSE (шаблон) — скопируйте в config.secrets.env и заполните.
# ============================================
# Файл config.secrets.env в .gitignore; в репозиторий не коммитить.
# Загрузка: автоматически, если config.secrets.env лежит рядом с config.env в корне проекта;
#   иначе задайте LSE_CONFIG_SECRETS=/абсолютный/путь/к/файлу (или CONFIG_SECRETS_FILE — то же).
# Непустые строки здесь перекрывают значения из config.env (и NYSE_CONFIG_PATH).
# Переменные окружения процесса (Docker environment:, export в shell) по-прежнему важнее файлов.

# DATABASE_URL=postgresql://user:pass@host:5432/lse_trading

# OPENAI_API_KEY=
# OPENAI_GPT_KEY=
# NEWSAPI_KEY=
# MARKETAUX_API_KEY=
# ALPHAVANTAGE_KEY=
# GEMINI_API_KEY=
# TELEGRAM_BOT_TOKEN=
# INVESTING_NEWS_PROXY=
# GITHUB_TOKEN=
