# GAME_5M exit tuning (merge into config.env on prod).
# Prevents TAKE_PROFIT on morning wick while close is in loss; aligns stale with hanger diagnostics.
# Apply: scripts/apply_game_5m_exit_config.sh (GCP) or paste keys manually.

GAME_5M_STALE_REVERSAL_EXIT_ENABLED=true
GAME_5M_STALE_REVERSAL_MIN_AGE_MINUTES=570
GAME_5M_STALE_REVERSAL_MAX_PNL_PCT=-2.5
GAME_5M_STALE_REVERSAL_MOMENTUM_BELOW=-0.3
# GAME_5M_STALE_REVERSAL_MAX_PNL_PCT_NBIS=-3.0
# GAME_5M_STALE_REVERSAL_MIN_AGE_MINUTES_NBIS=960

GAME_5M_EARLY_DERISK_ENABLED=true
GAME_5M_EARLY_DERISK_MIN_AGE_MINUTES=240
GAME_5M_EARLY_DERISK_MAX_LOSS_PCT=-2.2
GAME_5M_EARLY_DERISK_MOMENTUM_BELOW=-0.2

# Keep take-only for other exits; stale/derisk run before take when close < 0 (code).
GAME_5M_EXIT_ONLY_TAKE=true
